-- JARVIS Command Speaker Node
-- Version: 3.0.0-command-program-node
--
-- Sensible node model:
--   JARVIS sends one command:
--      play this TTS text, then play this music URL.
--
-- The node uses OpenAI TTS only if JarvisKey.lua is present.
-- It does not call GPT/chat. Main JARVIS supplies the text and music URL.
-- It fetches/plays the same programme locally through its attached speakers.

local VERSION = "3.0.8-command-node-sync-start"
local PROTOCOL = "JARVIS_PA_V1"

local NODE_LABEL = os.getComputerLabel() or ("SpeakerNode-" .. tostring(os.getComputerID()))

local TTS_VOLUME = 1.0
local MUSIC_VOLUME = 1.0
local AUDIO_CHUNK_SIZE = 16 * 1024

-- GPT/OpenAI TTS swap only.
-- Main JARVIS still sends the text and music URL.
-- This node keeps the working music path unchanged.
local KEY_FILE = "JarvisKey.lua"
local OPENAI_TTS_MODEL = "gpt-4o-mini-tts"
local OPENAI_TTS_VOICE = "cedar"
local OPENAI_TTS_RESPONSE_FORMAT = "pcm"
local OPENAI_TTS_PCM_CHUNK_SIZE = 4096
local OPENAI_TTS_TEXT_CHUNK_MAX = 300
local OPENAI_TTS_SPEED = 1.0

-- Terminal logging. This does not change playback.
local VERBOSE_LOGGING = true
local LOG_EVERY_AUDIO_CHUNKS = 10

-- OpenAI PCM is 24 kHz mono. CC speakers expect 48 kHz.
-- Duplicate each sample once to keep the correct speed.
local API_KEY = nil

local localSpeakers = {}
local cancelToken = 0

-- =============================================================================
-- HELPERS
-- =============================================================================

local function trim(s)
    return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function urlEncode(str)
    str = tostring(str or "")

    return str:gsub("([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
end

local function boolText(v)
    return v and "yes" or "no"
end

local function readAll(path)
    if not fs.exists(path) then return nil end

    local f = fs.open(path, "r")
    if not f then return nil end

    local data = f.readAll()
    f.close()

    return data
end

local function shortText(s, maxLen)
    s = tostring(s or "")
    maxLen = maxLen or 80

    s = s:gsub("\n", " "):gsub("\r", " ")

    if #s > maxLen then
        return s:sub(1, maxLen) .. "..."
    end

    return s
end

local function log(section, msg)
    if VERBOSE_LOGGING then
        print("[NODE][" .. tostring(section) .. "] " .. tostring(msg))
    end
end

local function responseCode(handle)
    if handle and handle.getResponseCode then
        local ok, code = pcall(function()
            return handle.getResponseCode()
        end)

        if ok and code then
            return tonumber(code) or tostring(code)
        end
    end

    return "?"
end


local function peripheralHasType(name, wanted)
    if not peripheral or not peripheral.getType then
        return false
    end

    if peripheral.hasType then
        local ok, result = pcall(function()
            return peripheral.hasType(name, wanted)
        end)

        if ok and result then
            return true
        end
    end

    local okType, pType = pcall(function()
        return peripheral.getType(name)
    end)

    if not okType then
        return false
    end

    if pType == wanted then
        return true
    end

    if type(pType) == "table" then
        for _, t in ipairs(pType) do
            if t == wanted then
                return true
            end
        end
    end

    return false
end

local function openAllModems()
    if not rednet or not rednet.open then
        print("[NODE] Rednet unavailable.")
        return 0
    end

    local opened = 0

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "modem") and not rednet.isOpen(name) then
            local ok, err = pcall(function()
                rednet.open(name)
            end)

            if ok then
                opened = opened + 1
            else
                print("[NODE] Could not open modem " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end

    return opened
end

local function scanSpeakers()
    localSpeakers = {}

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "speaker") then
            local wrapped = peripheral.wrap(name)

            if wrapped then
                localSpeakers[#localSpeakers + 1] = {
                    name = tostring(name),
                    speaker = wrapped,
                }
            end
        end
    end

    table.sort(localSpeakers, function(a, b)
        local an = tonumber(tostring(a.name):match("(%d+)$"))
        local bn = tonumber(tostring(b.name):match("(%d+)$"))

        if an and bn and an ~= bn then
            return an < bn
        end

        return tostring(a.name) < tostring(b.name)
    end)

    return localSpeakers
end

local function speakerNames()
    scanSpeakers()

    local names = {}

    for _, item in ipairs(localSpeakers) do
        names[#names + 1] = item.name
    end

    return names
end

local function stopAudio()
    scanSpeakers()

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
        end)
    end
end

local function waitSpeakerEmpty(speakerName)
    while true do
        local event, p1 = os.pullEvent("speaker_audio_empty")

        if p1 == nil or tostring(p1) == tostring(speakerName) then
            return true
        end
    end
end

local function playBufferOnSpeaker(item, buffer, volume)
    local name = tostring(item.name)

    while true do
        local ok, accepted = pcall(function()
            return item.speaker.playAudio(buffer, volume or 1)
        end)

        if ok and accepted then
            return true
        end

        if not ok then
            return false, tostring(accepted)
        end

        waitSpeakerEmpty(name)
    end
end

local function playBufferOnAll(buffer, volume)
    if type(buffer) ~= "table" then
        return false, "audio buffer was not a table"
    end

    scanSpeakers()

    if #localSpeakers == 0 then
        return false, "no local speakers"
    end

    for _, item in ipairs(localSpeakers) do
        local ok, err = playBufferOnSpeaker(item, buffer, volume or 1)

        if not ok then
            return false, tostring(item.name) .. ": " .. tostring(err)
        end
    end

    return true
end

local function playChime(volume)
    scanSpeakers()

    if #localSpeakers == 0 then
        return false, "no local speakers"
    end

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
            item.speaker.playSound("minecraft:block.note_block.chime", volume or 1, 1.0)
            sleep(0.12)
            item.speaker.playSound("minecraft:block.note_block.chime", volume or 1, 1.25)
        end)
    end

    return true
end

local function ack(to, commandId, ok, status, extra)
    if not to then return end

    local msg = {
        type = "ack",
        command_id = commandId,
        ok = ok,
        status = status,
        label = NODE_LABEL,
        speaker_count = #speakerNames(),
        speakers = speakerNames(),
        version = VERSION,
    }

    if extra then
        for k, v in pairs(extra) do
            msg[k] = v
        end
    end

    rednet.send(to, msg, PROTOCOL)
end

-- =============================================================================
-- AUDIO PLAYERS
-- =============================================================================

local function shouldContinue(token)
    return token == cancelToken
end

local function loadKey()
    local ok, result = pcall(function()
        return require("JarvisKey")
    end)

    if ok and type(result) == "table" then
        return result.OPENAI_API_KEY or result.api_key or result.key
    elseif ok and type(result) == "string" then
        return result
    end

    local raw = readAll(KEY_FILE)

    if raw then
        local key =
            raw:match("OPENAI_API_KEY%s*=%s*['\"]([^'\"]+)['\"]") or
            raw:match("api_key%s*=%s*['\"]([^'\"]+)['\"]") or
            raw:match("key%s*=%s*['\"]([^'\"]+)['\"]") or
            trim(raw)

        if key and key ~= "" then return key end
    end

    return nil
end

local function splitSpeechChunks(text, maxLen)
    text = trim(text or "")
    maxLen = maxLen or OPENAI_TTS_TEXT_CHUNK_MAX

    local chunks = {}

    while #text > maxLen do
        local head = text:sub(1, maxLen)
        local cut = head:match("^(.*[%.%!%?%;%:%。%！%？%；%：])")

        if cut and #cut > 60 then
            chunks[#chunks + 1] = trim(cut)
            text = trim(text:sub(#cut + 1))
        else
            chunks[#chunks + 1] = trim(head)
            text = trim(text:sub(maxLen + 1))
        end
    end

    if text ~= "" then
        chunks[#chunks + 1] = text
    end

    return chunks
end

local function pcm16leToSpeakerBuffer(chunk, carryByte)
    local out = {}
    local i = 1

    if carryByte ~= nil then
        if #chunk >= 1 then
            local lo = carryByte
            local hi = chunk:byte(1)
            local sample16 = lo + hi * 256

            if sample16 >= 32768 then
                sample16 = sample16 - 65536
            end

            local v = math.floor(sample16 / 256)

            if v > 127 then v = 127 end
            if v < -128 then v = -128 end

            out[#out + 1] = v
            out[#out + 1] = v

            carryByte = nil
            i = 2
        else
            return out, carryByte
        end
    end

    while i + 1 <= #chunk do
        local lo = chunk:byte(i)
        local hi = chunk:byte(i + 1)
        local sample16 = lo + hi * 256

        if sample16 >= 32768 then
            sample16 = sample16 - 65536
        end

        local v = math.floor(sample16 / 256)

        if v > 127 then v = 127 end
        if v < -128 then v = -128 end

        -- 24 kHz OpenAI PCM -> 48 kHz CC speaker audio.
        out[#out + 1] = v
        out[#out + 1] = v

        i = i + 2
    end

    if i <= #chunk then
        carryByte = chunk:byte(i)
    end

    return out, carryByte
end

local function speakOpenAIChunk(text, volume, token, voice, model, instructions)
    if not API_KEY then
        return false, "OpenAI key missing on node. Add JarvisKey.lua or run reloadkey."
    end

    if not http or not http.post then
        return false, "HTTP POST unavailable on node."
    end

    local usedVoice = voice or OPENAI_TTS_VOICE
    local usedModel = model or OPENAI_TTS_MODEL

    log("TTS", "Request start")
    log("TTS", "Text chars=" .. tostring(#tostring(text or "")) .. " preview=\"" .. shortText(text, 90) .. "\"")
    log("TTS", "Voice=" .. tostring(usedVoice) .. " | model=" .. tostring(usedModel) .. " | volume=" .. tostring(volume or TTS_VOLUME))
    log("TTS", "PCM read=" .. tostring(OPENAI_TTS_PCM_CHUNK_SIZE) .. " bytes | speed=" .. tostring(OPENAI_TTS_SPEED) .. " | conversion=24k->48k")

    local body = textutils.serializeJSON({
        model = usedModel,
        voice = usedVoice,
        input = text,
        instructions = instructions,
        response_format = OPENAI_TTS_RESPONSE_FORMAT,
        speed = OPENAI_TTS_SPEED,
    })

    log("TTS", "HTTP POST /v1/audio/speech")

    local response = http.post(
        "https://api.openai.com/v1/audio/speech",
        body,
        {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. API_KEY,
            ["User-Agent"] = "CC-JARVIS-SpeakerNode",
        },
        true
    )

    if not response then
        return false, "OpenAI TTS HTTP request failed."
    end

    local code = responseCode(response)
    log("TTS", "OpenAI HTTP " .. tostring(code))

    if code ~= "?" and tonumber(code) and tonumber(code) ~= 200 then
        local errBody = ""
        pcall(function()
            errBody = response.readAll() or ""
        end)
        response.close()
        return false, "OpenAI TTS HTTP " .. tostring(code) .. ": " .. shortText(errBody, 200)
    end

    local carryByte = nil
    local chunks = 0
    local rawBytes = 0
    local speakerSamples = 0

    while shouldContinue(token) do
        local raw = response.read(OPENAI_TTS_PCM_CHUNK_SIZE)
        if not raw then break end

        chunks = chunks + 1
        rawBytes = rawBytes + #raw

        local audio
        audio, carryByte = pcm16leToSpeakerBuffer(raw, carryByte)
        speakerSamples = speakerSamples + #audio

        if chunks == 1 then
            log("TTS", "First PCM chunk bytes=" .. tostring(#raw) .. " speakerSamples=" .. tostring(#audio))
        elseif chunks % LOG_EVERY_AUDIO_CHUNKS == 0 then
            log("TTS", "Progress chunks=" .. tostring(chunks) .. " rawBytes=" .. tostring(rawBytes) .. " speakerSamples=" .. tostring(speakerSamples))
        end

        if #audio > 0 then
            local ok, err = playBufferOnAll(audio, volume or TTS_VOLUME)

            if chunks == 1 then
                log("TTS", "First speaker buffer: " .. (ok and "accepted" or ("failed: " .. tostring(err))))
            end

            if not ok then
                response.close()
                return false, err
            end
        end
    end

    response.close()

    if not shouldContinue(token) then
        return false, "cancelled"
    end

    log("TTS", "Complete chunks=" .. tostring(chunks) .. " rawBytes=" .. tostring(rawBytes) .. " speakerSamples=" .. tostring(speakerSamples))
    return true, "GPT TTS played"
end


local function streamDfpwmUrl(url, volume, token, label)
    url = trim(url or "")
    label = tostring(label or "audio")

    if url == "" then
        log("MUSIC", label .. " skipped: no URL")
        return true, "no url"
    end

    if not http or not http.get then
        return false, "HTTP unavailable on node."
    end

    local dfpwm = require("cc.audio.dfpwm")
    local decoder = dfpwm.make_decoder()

    log("MUSIC", "Opening " .. label)
    log("MUSIC", "URL: " .. shortText(url, 110))
    log("MUSIC", "Chunk size: " .. tostring(AUDIO_CHUNK_SIZE) .. " bytes | volume=" .. tostring(volume or 1))

    local response = http.get(url, nil, true)

    if not response then
        return false, "HTTP request failed for " .. label
    end

    local code = responseCode(response)
    log("MUSIC", "HTTP " .. tostring(code))

    if code ~= "?" and tonumber(code) and tonumber(code) ~= 200 then
        local errBody = ""
        pcall(function()
            errBody = response.readAll() or ""
        end)
        response.close()
        return false, label .. " HTTP " .. tostring(code) .. ": " .. shortText(errBody, 180)
    end

    local chunks = 0
    local totalBytes = 0
    local totalSamples = 0

    while shouldContinue(token) do
        local chunk = response.read(AUDIO_CHUNK_SIZE)
        if not chunk then break end

        chunks = chunks + 1
        totalBytes = totalBytes + #chunk

        local audio = decoder(chunk)
        totalSamples = totalSamples + #audio

        if chunks == 1 then
            log("MUSIC", "First chunk bytes=" .. tostring(#chunk) .. " decodedSamples=" .. tostring(#audio))
        elseif chunks % LOG_EVERY_AUDIO_CHUNKS == 0 then
            log("MUSIC", "Progress chunks=" .. tostring(chunks) .. " bytes=" .. tostring(totalBytes) .. " samples=" .. tostring(totalSamples))
        end

        local ok, err = playBufferOnAll(audio, volume or 1)

        if chunks == 1 then
            log("MUSIC", "First speaker buffer: " .. (ok and "accepted" or ("failed: " .. tostring(err))))
        end

        if not ok then
            response.close()
            return false, err
        end
    end

    response.close()

    if not shouldContinue(token) then
        return false, "cancelled"
    end

    log("MUSIC", "Finished " .. label .. " | chunks=" .. tostring(chunks) .. " bytes=" .. tostring(totalBytes) .. " samples=" .. tostring(totalSamples))
    return true, "played"
end

local function playTtsText(text, volume, token, voice, model, instructions)
    text = trim(text or "")

    if text == "" then
        return true, "no TTS text"
    end

    local chunks = splitSpeechChunks(text, OPENAI_TTS_TEXT_CHUNK_MAX)

    for _, chunk in ipairs(chunks) do
        if not shouldContinue(token) then
            return false, "cancelled"
        end

        local ok, err = speakOpenAIChunk(chunk, volume or TTS_VOLUME, token, voice, model, instructions)

        if not ok then
            return false, err
        end
    end

    return true, "GPT TTS played"
end

local function playMusicUrl(url, name, volume, token)
    return streamDfpwmUrl(url, volume or MUSIC_VOLUME, token, "music: " .. tostring(name or "track"))
end

local function runProgramJob(job)
    local ok, result = true, "done"

    print("[NODE] Program from " .. tostring(job.sender) .. ": TTS then music.")
    log("JOB", "TTS chars=" .. tostring(#tostring(job.tts_text or "")) .. " | music=" .. tostring(job.music_name or "track"))
    log("JOB", "Music URL=" .. shortText(job.music_url, 110))

    ok, result = playTtsText(job.tts_text, job.tts_volume, job.token, job.tts_voice, job.tts_model, job.tts_instructions)

    if ok and shouldContinue(job.token) then
        log("JOB", "TTS finished; starting music.")
        ok, result = playMusicUrl(job.music_url, job.music_name, job.music_volume, job.token)
    else
        log("JOB", "Music skipped because TTS failed/cancelled: " .. tostring(result))
    end

    print("[NODE] Job finished: " .. tostring(ok and "OK" or "FAILED") .. " | " .. tostring(result))
    return ok, result
end

local function runSpeakJob(job)
    local ok, result = true, "done"

    print("[NODE] Speak from " .. tostring(job.sender))
    ok, result = playTtsText(job.text, job.volume, job.token, job.tts_voice, job.tts_model, job.tts_instructions)

    print("[NODE] Job finished: " .. tostring(ok and "OK" or "FAILED") .. " | " .. tostring(result))
    return ok, result
end

local function runMusicJob(job)
    local ok, result = true, "done"

    print("[NODE] Music from " .. tostring(job.sender) .. ": " .. tostring(job.name))
    ok, result = playMusicUrl(job.url, job.name, job.volume, job.token)

    print("[NODE] Job finished: " .. tostring(ok and "OK" or "FAILED") .. " | " .. tostring(result))
    return ok, result
end

-- =============================================================================
-- NETWORK LOOP
-- =============================================================================

local function listenerLoop()
    while true do
        local sender, msg = rednet.receive(PROTOCOL)

        if type(msg) == "table" then
            if msg.type == "discover" then
                ack(sender, msg.command_id, true, "hello", { response_type = "hello" })

            elseif msg.type == "stop" then
                cancelToken = cancelToken + 1
                stopAudio()
                ack(sender, msg.command_id, true, "stopped")

            elseif msg.type == "test_chime" then
                cancelToken = cancelToken + 1
                stopAudio()
                local ok, err = playChime(msg.volume or 1)
                ack(sender, msg.command_id, ok, ok and "chime sent" or tostring(err))

            elseif msg.type == "program" then
                -- No queue. The command is received and the programme starts immediately.
                cancelToken = cancelToken + 1
                stopAudio()

                local job = {
                    type = "program",
                    sender = sender,
                    command_id = msg.command_id,
                    tts_text = tostring(msg.tts_text or msg.text or ""),
                    music_url = tostring(msg.music_url or msg.url or ""),
                    music_name = tostring(msg.music_name or msg.name or "track"),
                    tts_volume = msg.tts_volume or TTS_VOLUME,
                    tts_voice = tostring(msg.voice or msg.tts_voice or OPENAI_TTS_VOICE),
                    tts_model = tostring(msg.tts_model or OPENAI_TTS_MODEL),
                    tts_instructions = msg.tts_instructions,
                    music_volume = msg.music_volume or MUSIC_VOLUME,
                    token = cancelToken,
                }

                ack(sender, msg.command_id, true, "program received; starting now")
                runProgramJob(job)

            elseif msg.type == "speak" then
                -- No queue. Speak immediately.
                cancelToken = cancelToken + 1
                stopAudio()

                local job = {
                    type = "speak",
                    sender = sender,
                    command_id = msg.command_id,
                    text = tostring(msg.text or ""),
                    volume = msg.volume or TTS_VOLUME,
                    tts_voice = tostring(msg.voice or msg.tts_voice or OPENAI_TTS_VOICE),
                    tts_model = tostring(msg.tts_model or OPENAI_TTS_MODEL),
                    tts_instructions = msg.tts_instructions,
                    token = cancelToken,
                }

                ack(sender, msg.command_id, true, "speak received; starting now")
                runSpeakJob(job)

            elseif msg.type == "music" then
                -- No queue. Music starts immediately.
                cancelToken = cancelToken + 1
                stopAudio()

                local job = {
                    type = "music",
                    sender = sender,
                    command_id = msg.command_id,
                    url = tostring(msg.url or ""),
                    name = tostring(msg.name or "track"),
                    volume = msg.volume or MUSIC_VOLUME,
                    token = cancelToken,
                }

                ack(sender, msg.command_id, true, "music received; starting now")
                runMusicJob(job)

            elseif msg.type == "set_label" then
                NODE_LABEL = tostring(msg.label or NODE_LABEL)
                os.setComputerLabel(NODE_LABEL)
                ack(sender, msg.command_id, true, "label set")
            end
        end
    end
end

local function commandLoop()
    while true do
        write("> ")
        local input = read()
        input = trim(input)
        local lower = input:lower()

        if lower == "status" or lower == "speakers" then
            scanSpeakers()
            print("Node: " .. tostring(NODE_LABEL))
            print("ID: " .. tostring(os.getComputerID()))
            print("Version: " .. VERSION)
            print("Protocol: " .. PROTOCOL)
            print("HTTP for public audio URLs: " .. boolText(http and http.get))
            print("OpenAI key: " .. boolText(API_KEY ~= nil))
            print("OpenAI voice default: " .. OPENAI_TTS_VOICE)
            print("Verbose logging: " .. boolText(VERBOSE_LOGGING))
            print("Speakers: " .. tostring(#localSpeakers))
            for i, item in ipairs(localSpeakers) do
                print("  " .. tostring(i) .. ". " .. tostring(item.name))
            end

        elseif lower == "chime" or lower == "test" then
            playChime(1)

        elseif lower == "reloadkey" then
            API_KEY = loadKey()
            print("OpenAI key: " .. boolText(API_KEY ~= nil))

        elseif lower == "verbose" then
            VERBOSE_LOGGING = not VERBOSE_LOGGING
            print("Verbose logging: " .. boolText(VERBOSE_LOGGING))

        elseif lower == "stop" then
            cancelToken = cancelToken + 1
            stopAudio()
            print("Stopped.")

        elseif lower == "clear" then
            term.clear()
            term.setCursorPos(1, 1)

        elseif lower == "exit" then
            cancelToken = cancelToken + 1
            stopAudio()
            error("Terminated", 0)

        elseif lower ~= "" then
            print("Commands: status, speakers, chime, reloadkey, verbose, stop, clear, exit")
        end
    end
end

-- =============================================================================
-- STARTUP
-- =============================================================================

openAllModems()
scanSpeakers()
API_KEY = loadKey()

print("")
print("JARVIS COMMAND SPEAKER NODE")
print("Version: " .. VERSION)
print("Computer ID: " .. tostring(os.getComputerID()))
print("Label: " .. tostring(NODE_LABEL))
print("Protocol: " .. PROTOCOL)
print("Role: receive same JARVIS programme and immediately play GPT TTS, then music")
print("HTTP: used for OpenAI TTS and public music URLs")
print("OpenAI key: " .. boolText(API_KEY ~= nil))
print("GPT note: no chat/GPT prompt calls, only TTS audio.")
print("Queue: none. Programme commands ACK and start immediately.")
print("Local speakers: " .. tostring(#localSpeakers))
for i, item in ipairs(localSpeakers) do
    print("  " .. tostring(i) .. ". " .. tostring(item.name))
end
print("Sync: starts immediately after programme command ACK.")
print("Waiting for JARVIS commands...")
print("")

parallel.waitForAny(listenerLoop, commandLoop)
