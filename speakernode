-- JARVIS Smart Command Speaker Node
-- Version: 3.1.0-command-node-openai-tts
--
-- This node is an extension of JARVIS for local speakers.
--
-- It receives a high-level command from the main JARVIS computer:
--   1. Say this TTS text using this voice/instructions.
--   2. Then play this music URL.
--
-- Cost control:
--   - This node does NOT call GPT/chat/completions/responses.
--   - It only calls OpenAI TTS if JarvisKey.lua exists on this node.
--   - One node = one extra TTS request per broadcast it plays.
--   - If there is no JarvisKey.lua, it falls back to the free legacy TTS voice,
--     which will NOT match the OpenAI voice.
--
-- Music:
--   - Music is fetched from the URL JARVIS sends.
--   - No API key is used for music.

local VERSION = "3.1.0-command-node-openai-tts"
local PROTOCOL = "JARVIS_PA_V1"

local NODE_LABEL = os.getComputerLabel() or ("SpeakerNode-" .. tostring(os.getComputerID()))

local KEY_FILE = "JarvisKey.lua"

local DEFAULT_TTS_PROVIDER = "openai" -- "openai" or "legacy"
local DEFAULT_OPENAI_TTS_MODEL = "gpt-4o-mini-tts"
local DEFAULT_OPENAI_TTS_VOICE = "cedar"
local OPENAI_TTS_RESPONSE_FORMAT = "pcm"
local OPENAI_TTS_PCM_CHUNK_SIZE = 65536

local TTS_VOLUME = 1.0
local MUSIC_VOLUME = 1.0
local MUSIC_CHUNK_SIZE = 16 * 1024
local LEGACY_TTS_CHUNK_SIZE = 16 * 1024

local OPENAI_TTS_INSTRUCTIONS = [=[
Speak clearly and naturally over a Minecraft public-address speaker.
Use a firm, official JARVIS announcer style.
Keep the voice intelligible and avoid mumbling or distortion.
]=]

local MORNING_TTS_INSTRUCTIONS = [=[
Speak in Mandarin Chinese, Putonghua.
Tone: angry, severe, commanding, official, disciplined, and impatient with disorder.
Delivery: forceful public-address cadence, sharp emphasis, clear pronunciation.
Do not scream, distort, mumble, or become cartoonish.
Keep the voice intelligible over Minecraft speakers.
]=]

local localSpeakers = {}
local currentJob = nil
local cancelToken = 0
local API_KEY = nil

-- =============================================================================
-- HELPERS
-- =============================================================================

local function trim(s)
    return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function urlEncode(str)
    str = tostring(str or "")

    return str:gsub("([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
end

local function boolText(v)
    return v and "yes" or "no"
end

local function readAll(path)
    if not fs.exists(path) then return nil end

    local f = fs.open(path, "r")
    if not f then return nil end

    local data = f.readAll()
    f.close()

    return data
end

local function peripheralHasType(name, wanted)
    if not peripheral or not peripheral.getType then
        return false
    end

    if peripheral.hasType then
        local ok, result = pcall(function()
            return peripheral.hasType(name, wanted)
        end)

        if ok and result then
            return true
        end
    end

    local okType, pType = pcall(function()
        return peripheral.getType(name)
    end)

    if not okType then
        return false
    end

    if pType == wanted then
        return true
    end

    if type(pType) == "table" then
        for _, t in ipairs(pType) do
            if t == wanted then
                return true
            end
        end
    end

    return false
end

local function splitSpeechChunks(text, maxLen)
    text = trim(text or "")
    maxLen = maxLen or 700

    local chunks = {}

    while #text > maxLen do
        local head = text:sub(1, maxLen)
        local cut = head:match("^(.*[%.%!%?%;%:%。%！%？%；%：])")

        if cut and #cut > 80 then
            chunks[#chunks + 1] = trim(cut)
            text = trim(text:sub(#cut + 1))
        else
            chunks[#chunks + 1] = trim(head)
            text = trim(text:sub(maxLen + 1))
        end
    end

    if text ~= "" then
        chunks[#chunks + 1] = text
    end

    return chunks
end

local function openAllModems()
    if not rednet or not rednet.open then
        print("[NODE] Rednet unavailable.")
        return 0
    end

    local opened = 0

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "modem") and not rednet.isOpen(name) then
            local ok, err = pcall(function()
                rednet.open(name)
            end)

            if ok then
                opened = opened + 1
            else
                print("[NODE] Could not open modem " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end

    return opened
end

local function scanSpeakers()
    localSpeakers = {}

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "speaker") then
            local wrapped = peripheral.wrap(name)

            if wrapped then
                localSpeakers[#localSpeakers + 1] = {
                    name = tostring(name),
                    speaker = wrapped,
                }
            end
        end
    end

    table.sort(localSpeakers, function(a, b)
        local an = tonumber(tostring(a.name):match("(%d+)$"))
        local bn = tonumber(tostring(b.name):match("(%d+)$"))

        if an and bn and an ~= bn then
            return an < bn
        end

        return tostring(a.name) < tostring(b.name)
    end)

    return localSpeakers
end

local function speakerNames()
    scanSpeakers()

    local names = {}

    for _, item in ipairs(localSpeakers) do
        names[#names + 1] = item.name
    end

    return names
end

local function stopAudio()
    scanSpeakers()

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
        end)
    end
end

local function waitSpeakerEmpty(speakerName)
    while true do
        local event, p1 = os.pullEvent("speaker_audio_empty")

        if p1 == nil or tostring(p1) == tostring(speakerName) then
            return true
        end
    end
end

local function playBufferOnSpeaker(item, buffer, volume)
    local name = tostring(item.name)

    while true do
        local ok, accepted = pcall(function()
            return item.speaker.playAudio(buffer, volume or 1)
        end)

        if ok and accepted then
            return true
        end

        if not ok then
            return false, tostring(accepted)
        end

        waitSpeakerEmpty(name)
    end
end

local function playBufferOnAll(buffer, volume)
    if type(buffer) ~= "table" then
        return false, "audio buffer was not a table"
    end

    scanSpeakers()

    if #localSpeakers == 0 then
        return false, "no local speakers"
    end

    for _, item in ipairs(localSpeakers) do
        local ok, err = playBufferOnSpeaker(item, buffer, volume or 1)

        if not ok then
            return false, tostring(item.name) .. ": " .. tostring(err)
        end
    end

    return true
end

local function playChime(volume)
    scanSpeakers()

    if #localSpeakers == 0 then
        return false, "no local speakers"
    end

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
            item.speaker.playSound("minecraft:block.note_block.chime", volume or 1, 1.0)
            sleep(0.12)
            item.speaker.playSound("minecraft:block.note_block.chime", volume or 1, 1.25)
        end)
    end

    return true
end

local function ack(to, commandId, ok, status, extra)
    if not to then return end

    local msg = {
        type = "ack",
        command_id = commandId,
        ok = ok,
        status = status,
        label = NODE_LABEL,
        speaker_count = #speakerNames(),
        speakers = speakerNames(),
        version = VERSION,
    }

    if extra then
        for k, v in pairs(extra) do
            msg[k] = v
        end
    end

    rednet.send(to, msg, PROTOCOL)
end

-- =============================================================================
-- API KEY / TTS AUDIO
-- =============================================================================

local function loadKey()
    local ok, result = pcall(function()
        return require("JarvisKey")
    end)

    if ok and type(result) == "table" then
        return result.OPENAI_API_KEY or result.api_key or result.key
    elseif ok and type(result) == "string" then
        return result
    end

    local raw = readAll(KEY_FILE)

    if raw then
        local key =
            raw:match("OPENAI_API_KEY%s*=%s*['\"]([^'\"]+)['\"]") or
            raw:match("api_key%s*=%s*['\"]([^'\"]+)['\"]") or
            raw:match("key%s*=%s*['\"]([^'\"]+)['\"]") or
            trim(raw)

        if key and key ~= "" then return key end
    end

    return nil
end

local function pcm16leToSpeakerBuffer(chunk)
    local out = {}
    local oi = 1

    for i = 1, #chunk - 1, 2 do
        local lo = chunk:byte(i)
        local hi = chunk:byte(i + 1)

        local sample = hi * 256 + lo
        if sample >= 32768 then sample = sample - 65536 end

        local v = math.floor(sample / 256)

        if v > 127 then v = 127 end
        if v < -128 then v = -128 end

        out[oi] = v
        oi = oi + 1
    end

    return out
end

local function shouldContinue(token)
    return token == cancelToken
end

local function speakOpenAI(text, voice, model, instructions, volume, token)
    if not API_KEY then
        return false, "OpenAI key missing on node."
    end

    if not http or not http.post then
        return false, "HTTP unavailable on node."
    end

    local payload = textutils.serializeJSON({
        model = model or DEFAULT_OPENAI_TTS_MODEL,
        voice = voice or DEFAULT_OPENAI_TTS_VOICE,
        input = text,
        instructions = instructions or OPENAI_TTS_INSTRUCTIONS,
        response_format = OPENAI_TTS_RESPONSE_FORMAT,
    })

    print("[NODE] OpenAI TTS: voice=" .. tostring(voice or DEFAULT_OPENAI_TTS_VOICE))

    local response = http.post("https://api.openai.com/v1/audio/speech", payload, {
        ["Content-Type"] = "application/json",
        ["Authorization"] = "Bearer " .. API_KEY,
    }, true)

    if not response then
        return false, "OpenAI TTS HTTP request failed."
    end

    while shouldContinue(token) do
        local chunk = response.read(OPENAI_TTS_PCM_CHUNK_SIZE)
        if not chunk then break end

        local audio = pcm16leToSpeakerBuffer(chunk)

        if #audio > 0 then
            local ok, err = playBufferOnAll(audio, volume or TTS_VOLUME)

            if not ok then
                response.close()
                return false, err
            end
        end
    end

    response.close()

    if not shouldContinue(token) then
        return false, "cancelled"
    end

    return true, "OpenAI TTS played"
end

local function streamDfpwmUrl(url, volume, token, label)
    url = trim(url or "")

    if url == "" then
        return true, "no url"
    end

    if not http or not http.get then
        return false, "HTTP unavailable on node."
    end

    local dfpwm = require("cc.audio.dfpwm")
    local decoder = dfpwm.make_decoder()

    print("[NODE] Opening " .. tostring(label or "audio") .. "...")
    local response = http.get(url, nil, true)

    if not response then
        return false, "HTTP request failed for " .. tostring(label or url)
    end

    local chunks = 0

    while shouldContinue(token) do
        local chunk = response.read(MUSIC_CHUNK_SIZE)
        if not chunk then break end

        chunks = chunks + 1
        local audio = decoder(chunk)
        local ok, err = playBufferOnAll(audio, volume or 1)

        if not ok then
            response.close()
            return false, err
        end
    end

    response.close()

    if not shouldContinue(token) then
        return false, "cancelled"
    end

    print("[NODE] Finished " .. tostring(label or "audio") .. ". Chunks=" .. tostring(chunks))
    return true, "played"
end

local function speakLegacy(text, volume, token)
    local url = "https://music.madefor.cc/tts?text=" .. urlEncode(text)
    return streamDfpwmUrl(url, volume or TTS_VOLUME, token, "legacy TTS")
end

local function playTtsText(text, provider, voice, model, instructions, volume, token)
    text = trim(text or "")

    if text == "" then
        return true, "no TTS text"
    end

    local chunks = splitSpeechChunks(text, 700)

    for i, chunk in ipairs(chunks) do
        if not shouldContinue(token) then
            return false, "cancelled"
        end

        local ok, err

        if provider == "legacy" then
            ok, err = speakLegacy(chunk, volume, token)
        else
            ok, err = speakOpenAI(chunk, voice, model, instructions, volume, token)

            if not ok then
                print("[NODE] OpenAI TTS failed: " .. tostring(err))
                print("[NODE] Falling back to legacy TTS.")
                ok, err = speakLegacy(chunk, volume, token)
            end
        end

        if not ok then
            return false, err
        end
    end

    return true, "TTS played"
end

local function playMusicUrl(url, name, volume, token)
    return streamDfpwmUrl(url, volume or MUSIC_VOLUME, token, "music: " .. tostring(name or "track"))
end

local function setJob(job)
    cancelToken = cancelToken + 1
    stopAudio()

    job.token = cancelToken
    currentJob = job
    os.queueEvent("jarvis_node_job")
end

-- =============================================================================
-- NETWORK LOOP
-- =============================================================================

local function listenerLoop()
    while true do
        local sender, msg = rednet.receive(PROTOCOL)

        if type(msg) == "table" then
            if msg.type == "discover" then
                ack(sender, msg.command_id, true, "hello", { response_type = "hello" })

            elseif msg.type == "stop" then
                cancelToken = cancelToken + 1
                currentJob = nil
                stopAudio()
                ack(sender, msg.command_id, true, "stopped")

            elseif msg.type == "test_chime" then
                cancelToken = cancelToken + 1
                stopAudio()
                local ok, err = playChime(msg.volume or 1)
                ack(sender, msg.command_id, ok, ok and "chime sent" or tostring(err))

            elseif msg.type == "program" then
                setJob({
                    type = "program",
                    sender = sender,
                    command_id = msg.command_id,
                    tts_text = tostring(msg.tts_text or msg.text or ""),
                    tts_provider = tostring(msg.tts_provider or DEFAULT_TTS_PROVIDER),
                    voice = tostring(msg.voice or DEFAULT_OPENAI_TTS_VOICE),
                    tts_model = tostring(msg.tts_model or DEFAULT_OPENAI_TTS_MODEL),
                    tts_instructions = tostring(msg.tts_instructions or OPENAI_TTS_INSTRUCTIONS),
                    music_url = tostring(msg.music_url or msg.url or ""),
                    music_name = tostring(msg.music_name or msg.name or "track"),
                    tts_volume = msg.tts_volume or TTS_VOLUME,
                    music_volume = msg.music_volume or MUSIC_VOLUME,
                })

                ack(sender, msg.command_id, true, "program queued")

            elseif msg.type == "speak" then
                setJob({
                    type = "speak",
                    sender = sender,
                    command_id = msg.command_id,
                    text = tostring(msg.text or ""),
                    tts_provider = tostring(msg.tts_provider or DEFAULT_TTS_PROVIDER),
                    voice = tostring(msg.voice or DEFAULT_OPENAI_TTS_VOICE),
                    tts_model = tostring(msg.tts_model or DEFAULT_OPENAI_TTS_MODEL),
                    tts_instructions = tostring(msg.tts_instructions or OPENAI_TTS_INSTRUCTIONS),
                    volume = msg.volume or TTS_VOLUME,
                })

                ack(sender, msg.command_id, true, "speak queued")

            elseif msg.type == "music" then
                setJob({
                    type = "music",
                    sender = sender,
                    command_id = msg.command_id,
                    url = tostring(msg.url or ""),
                    name = tostring(msg.name or "track"),
                    volume = msg.volume or MUSIC_VOLUME,
                })

                ack(sender, msg.command_id, true, "music queued")

            elseif msg.type == "set_label" then
                NODE_LABEL = tostring(msg.label or NODE_LABEL)
                os.setComputerLabel(NODE_LABEL)
                ack(sender, msg.command_id, true, "label set")
            end
        end
    end
end

local function workerLoop()
    while true do
        os.pullEvent("jarvis_node_job")

        local job = currentJob
        currentJob = nil

        if job then
            local ok, result = true, "done"

            if job.type == "program" then
                print("[NODE] Program from " .. tostring(job.sender) .. ": TTS then music.")
                print("[NODE] TTS provider=" .. tostring(job.tts_provider) .. " voice=" .. tostring(job.voice))
                ok, result = playTtsText(job.tts_text, job.tts_provider, job.voice, job.tts_model, job.tts_instructions, job.tts_volume, job.token)

                if ok and shouldContinue(job.token) then
                    ok, result = playMusicUrl(job.music_url, job.music_name, job.music_volume, job.token)
                end

            elseif job.type == "speak" then
                print("[NODE] Speak from " .. tostring(job.sender))
                print("[NODE] TTS provider=" .. tostring(job.tts_provider) .. " voice=" .. tostring(job.voice))
                ok, result = playTtsText(job.text, job.tts_provider, job.voice, job.tts_model, job.tts_instructions, job.volume, job.token)

            elseif job.type == "music" then
                print("[NODE] Music from " .. tostring(job.sender) .. ": " .. tostring(job.name))
                ok, result = playMusicUrl(job.url, job.name, job.volume, job.token)
            end

            ack(job.sender, job.command_id, ok, result)
            print("[NODE] Job finished: " .. tostring(result))
        end
    end
end

local function commandLoop()
    while true do
        write("> ")
        local input = read()
        input = trim(input)
        local lower = input:lower()

        if lower == "status" or lower == "speakers" then
            scanSpeakers()
            print("Node: " .. tostring(NODE_LABEL))
            print("ID: " .. tostring(os.getComputerID()))
            print("Version: " .. VERSION)
            print("Protocol: " .. PROTOCOL)
            print("HTTP: " .. boolText(http and http.get))
            print("OpenAI key: " .. boolText(API_KEY ~= nil))
            print("Default provider: " .. DEFAULT_TTS_PROVIDER)
            print("Default voice: " .. DEFAULT_OPENAI_TTS_VOICE)
            print("Speakers: " .. tostring(#localSpeakers))
            for i, item in ipairs(localSpeakers) do
                print("  " .. tostring(i) .. ". " .. tostring(item.name))
            end

        elseif lower == "chime" or lower == "test" then
            playChime(1)

        elseif lower == "reloadkey" then
            API_KEY = loadKey()
            print("OpenAI key: " .. boolText(API_KEY ~= nil))

        elseif lower == "stop" then
            cancelToken = cancelToken + 1
            stopAudio()
            print("Stopped.")

        elseif lower == "clear" then
            term.clear()
            term.setCursorPos(1, 1)

        elseif lower == "exit" then
            cancelToken = cancelToken + 1
            stopAudio()
            error("Terminated", 0)

        elseif lower ~= "" then
            print("Commands: status, speakers, chime, reloadkey, stop, clear, exit")
        end
    end
end

-- =============================================================================
-- STARTUP
-- =============================================================================

openAllModems()
scanSpeakers()
API_KEY = loadKey()

print("")
print("JARVIS SMART COMMAND SPEAKER NODE")
print("Version: " .. VERSION)
print("Computer ID: " .. tostring(os.getComputerID()))
print("Label: " .. tostring(NODE_LABEL))
print("Protocol: " .. PROTOCOL)
print("Role: receive JARVIS command, use same voice/instructions, then play music")
print("OpenAI key: " .. boolText(API_KEY ~= nil))
print("Cost note: no GPT calls; OpenAI TTS only if key is present.")
print("Music: fetched from JARVIS-selected URL")
print("Local speakers: " .. tostring(#localSpeakers))
for i, item in ipairs(localSpeakers) do
    print("  " .. tostring(i) .. ". " .. tostring(item.name))
end
print("Waiting for JARVIS commands...")
print("")

parallel.waitForAny(listenerLoop, workerLoop, commandLoop)
