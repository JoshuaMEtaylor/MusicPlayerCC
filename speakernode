-- JARVIS Dumb Speaker Terminal Node
-- Version: 2.0.0-dumb-audio-relay
--
-- Purpose:
--   This node does NOT fetch HTTP.
--   This node does NOT use an OpenAI API key.
--   This node does NOT generate TTS.
--
-- JARVIS main computer generates/decodes all audio and sends raw speaker buffers
-- over rednet. This node simply receives those buffers and plays them through
-- every speaker it can see locally.
--
-- Setup:
--   1. Put this on a computer near the broken/new speaker branch.
--   2. Attach wireless/ender modem to this computer.
--   3. Attach one speaker directly OR attach a small local wired speaker branch.
--   4. Run this script as startup.

local VERSION = "2.1.0-dumb-node-synced-start"
local PROTOCOL = "JARVIS_PA_V1"

local NODE_LABEL = os.getComputerLabel() or ("SpeakerNode-" .. tostring(os.getComputerID()))

local localSpeakers = {}
local audioQueue = {}
local currentStreamId = nil
local streamPlaying = false
local queueLimit = 256

-- =============================================================================
-- HELPERS
-- =============================================================================

local function trim(s)
    return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function boolText(v)
    return v and "yes" or "no"
end

local function peripheralHasType(name, wanted)
    if not peripheral or not peripheral.getType then
        return false
    end

    -- Compatibility with older CC builds that do not have peripheral.hasType.
    if peripheral.hasType then
        local ok, result = pcall(function()
            return peripheral.hasType(name, wanted)
        end)

        if ok and result then
            return true
        end
    end

    local okType, pType = pcall(function()
        return peripheral.getType(name)
    end)

    if not okType then
        return false
    end

    if pType == wanted then
        return true
    end

    if type(pType) == "table" then
        for _, t in ipairs(pType) do
            if t == wanted then
                return true
            end
        end
    end

    return false
end

local function openAllModems()
    local opened = 0

    if not rednet or not rednet.open then
        print("[NODE] Rednet unavailable.")
        return 0
    end

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "modem") and not rednet.isOpen(name) then
            local ok, err = pcall(function()
                rednet.open(name)
            end)

            if ok then
                opened = opened + 1
            else
                print("[NODE] Could not open modem " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end

    return opened
end

local function scanSpeakers()
    localSpeakers = {}

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "speaker") then
            local wrapped = peripheral.wrap(name)

            if wrapped then
                localSpeakers[#localSpeakers + 1] = {
                    name = tostring(name),
                    speaker = wrapped,
                }
            end
        end
    end

    table.sort(localSpeakers, function(a, b)
        local an = tonumber(tostring(a.name):match("(%d+)$"))
        local bn = tonumber(tostring(b.name):match("(%d+)$"))

        if an and bn and an ~= bn then
            return an < bn
        end

        return tostring(a.name) < tostring(b.name)
    end)

    return localSpeakers
end

local function speakerNames()
    scanSpeakers()

    local names = {}

    for _, item in ipairs(localSpeakers) do
        names[#names + 1] = item.name
    end

    return names
end

local function stopAudio()
    scanSpeakers()

    audioQueue = {}

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
        end)
    end
end

local function waitSpeakerEmpty(speakerName)
    while true do
        local event, p1 = os.pullEvent("speaker_audio_empty")

        if p1 == nil or tostring(p1) == tostring(speakerName) then
            return true
        end
    end
end

local function playBufferOnSpeaker(item, buffer, volume)
    local name = tostring(item.name)

    while true do
        local ok, accepted = pcall(function()
            return item.speaker.playAudio(buffer, volume or 1)
        end)

        if ok and accepted then
            return true
        end

        if not ok then
            return false, tostring(accepted)
        end

        waitSpeakerEmpty(name)
    end
end

local function playBufferOnAll(buffer, volume)
    if type(buffer) ~= "table" then
        return false, "audio buffer was not a table"
    end

    scanSpeakers()

    if #localSpeakers == 0 then
        return false, "no local speakers"
    end

    for _, item in ipairs(localSpeakers) do
        local ok, err = playBufferOnSpeaker(item, buffer, volume or 1)

        if not ok then
            return false, tostring(item.name) .. ": " .. tostring(err)
        end
    end

    return true
end

local function playChime(volume)
    scanSpeakers()

    if #localSpeakers == 0 then
        return false, "no local speakers"
    end

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
            item.speaker.playSound("minecraft:block.note_block.chime", volume or 1, 1.0)
            sleep(0.12)
            item.speaker.playSound("minecraft:block.note_block.chime", volume or 1, 1.25)
        end)
    end

    return true
end

local function ack(to, commandId, ok, status, extra)
    local msg = {
        type = "ack",
        command_id = commandId,
        ok = ok,
        status = status,
        label = NODE_LABEL,
        speaker_count = #speakerNames(),
        speakers = speakerNames(),
        version = VERSION,
    }

    if extra then
        for k, v in pairs(extra) do
            msg[k] = v
        end
    end

    rednet.send(to, msg, PROTOCOL)
end

local function clearStream(streamId)
    currentStreamId = streamId
    streamPlaying = false
    audioQueue = {}

    for _, item in ipairs(localSpeakers) do
        pcall(function()
            item.speaker.stop()
        end)
    end
end

local function enqueueAudiolocal function enqueueAudio(msg)
    local streamId = tostring(msg.stream_id or "default")

    if currentStreamId ~= streamId then
        clearStream(streamId)
        print("[NODE] New audio stream: " .. streamId .. " (waiting for play)")
    end

    if #audioQueue >= queueLimit then
        table.remove(audioQueue, 1)
        print("[NODE] Queue full; dropped oldest packet.")
    end

    audioQueue[#audioQueue + 1] = {
        buffer = msg.buffer,
        volume = msg.volume or 1,
    }

    if streamPlaying then
        os.queueEvent("jarvis_node_audio")
    end
end

local function beginStream(streamId)
    streamId = tostring(streamId or currentStreamId or "default")

    if currentStreamId ~= streamId then
        currentStreamId = streamId
    end

    streamPlaying = true
    print("[NODE] Stream play: " .. tostring(currentStreamId) .. " | queued=" .. tostring(#audioQueue))
    os.queueEvent("jarvis_node_audio")
end

-- =============================================================================
-- LOOPS
-- =============================================================================

local function listenerLoop()
    while true do
        local sender, msg = rednet.receive(PROTOCOL)

        if type(msg) == "table" then
            if msg.type == "discover" then
                ack(sender, msg.command_id, true, "hello", { response_type = "hello" })

            elseif msg.type == "stop" then
                clearStream("stopped-" .. tostring(os.clock()))
                stopAudio()
                ack(sender, msg.command_id, true, "stopped")

            elseif msg.type == "test_chime" then
                stopAudio()
                local ok, err = playChime(msg.volume or 1)
                ack(sender, msg.command_id, ok, ok and "chime sent" or tostring(err))

            elseif msg.type == "stream_start" then
                clearStream(tostring(msg.stream_id or "stream"))
                ack(sender, msg.command_id, true, "stream prebuffering")

            elseif msg.type == "stream_play" then
                beginStream(tostring(msg.stream_id or currentStreamId or "stream"))
                ack(sender, msg.command_id, true, "stream playing")

            elseif msg.type == "audio" then
                -- No ack per audio packet. That would spam rednet and slow the stream.
                enqueueAudio(msg)

            elseif msg.type == "set_label" then
                NODE_LABEL = tostring(msg.label or NODE_LABEL)
                os.setComputerLabel(NODE_LABEL)
                ack(sender, msg.command_id, true, "label set")
            end
        end
    end
end

local function audioWorkerLoop()
    while true do
        if #audioQueue == 0 then
            os.pullEvent("jarvis_node_audio")
        else
            local packet = table.remove(audioQueue, 1)
            local ok, err = playBufferOnAll(packet.buffer, packet.volume)

            if not ok then
                print("[NODE] Audio error: " .. tostring(err))
            end
        end
    end
end

local function commandLoop()
    while true do
        write("> ")
        local input = read()
        input = trim(input)
        local lower = input:lower()

        if lower == "status" or lower == "speakers" then
            scanSpeakers()
            print("Node: " .. tostring(NODE_LABEL))
            print("ID: " .. tostring(os.getComputerID()))
            print("Version: " .. VERSION)
            print("Protocol: " .. PROTOCOL)
            print("Speakers: " .. tostring(#localSpeakers))
            for i, item in ipairs(localSpeakers) do
                print("  " .. tostring(i) .. ". " .. tostring(item.name))
            end
            print("Queue: " .. tostring(#audioQueue))
            print("Current stream: " .. tostring(currentStreamId))
            print("Playing: " .. boolText(streamPlaying))

        elseif lower == "chime" or lower == "test" then
            playChime(1)

        elseif lower == "stop" then
            stopAudio()
            print("Stopped.")

        elseif lower == "clear" then
            term.clear()
            term.setCursorPos(1, 1)

        elseif lower == "exit" then
            stopAudio()
            error("Terminated", 0)

        elseif lower ~= "" then
            print("Commands: status, speakers, chime, stop, clear, exit")
        end
    end
end

-- =============================================================================
-- STARTUP
-- =============================================================================

openAllModems()
scanSpeakers()

print("")
print("JARVIS DUMB SPEAKER NODE")
print("Version: " .. VERSION)
print("Computer ID: " .. tostring(os.getComputerID()))
print("Label: " .. tostring(NODE_LABEL))
print("Protocol: " .. PROTOCOL)
print("HTTP/API: not used on this node")
print("Local speakers: " .. tostring(#localSpeakers))
for i, item in ipairs(localSpeakers) do
    print("  " .. tostring(i) .. ". " .. tostring(item.name))
end
print("Waiting for raw audio packets from JARVIS...")
print("Sync mode: prebuffer until stream_play, then local speakers start.")
print("")

parallel.waitForAny(listenerLoop, audioWorkerLoop, commandLoop)
