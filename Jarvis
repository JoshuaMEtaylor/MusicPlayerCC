local mirrorMonitors = {}
local mirrorStarted = false

local function forceMonitorFit(mon)
    if not mon then return end

    -- 0.5 is the smallest ComputerCraft monitor text scale.
    -- This makes larger monitors show more text instead of huge stretched text.
    pcall(function()
        mon.setTextScale(0.5)
    end)
end

local function periphHasType(name, wanted)
    if peripheral.hasType then
        local ok, result = pcall(function()
            return peripheral.hasType(name, wanted)
        end)
        if ok and result then return true end
    end

    local pType = peripheral.getType(name)

    if pType == wanted then return true end

    if type(pType) == "table" then
        for _, t in ipairs(pType) do
            if t == wanted then return true end
        end
    end

    return false
end

local function mirrorScanMonitors()
    mirrorMonitors = {}

    if not MONITOR_MIRROR_ENABLED then
        return mirrorMonitors
    end

    for _, name in ipairs(peripheral.getNames()) do
        if periphHasType(name, "monitor") then
            local mon = peripheral.wrap(name)

            if mon and mon.getSize then
                pcall(function()
                    forceMonitorFit(mon)
                    mon.clear()
                    mon.setCursorPos(1, 1)
                end)

                forceMonitorFit(mon)
                local w, h = mon.getSize()

                mirrorMonitors[#mirrorMonitors + 1] = {
                    name = tostring(name),
                    monitor = mon,
                    width = tonumber(w) or 0,
                    height = tonumber(h) or 0,
                }
            end
        end
    end

    table.sort(mirrorMonitors, function(a, b)
        return tostring(a.name) < tostring(b.name)
    end)

    return mirrorMonitors
end

local function mirrorScrollIfNeeded(item)
    local mon = item.monitor
    local w, h = mon.getSize()
    local x, y = mon.getCursorPos()

    if y > h then
        mon.scroll(1)
        mon.setCursorPos(1, h)
    end
end

local function mirrorWriteRaw(value)
    if not mirrorStarted or #mirrorMonitors == 0 then
        return
    end

    local textValue = tostring(value or "")

    for _, item in ipairs(mirrorMonitors) do
        pcall(function()
            local mon = item.monitor
            local w, h = mon.getSize()

            local i = 1
            while i <= #textValue do
                local ch = textValue:sub(i, i)

                if ch == "\n" then
                    local x, y = mon.getCursorPos()
                    mon.setCursorPos(1, y + 1)
                    mirrorScrollIfNeeded(item)
                else
                    mirrorScrollIfNeeded(item)

                    local x, y = mon.getCursorPos()

                    if x > w then
                        mon.setCursorPos(1, y + 1)
                        mirrorScrollIfNeeded(item)
                        x, y = mon.getCursorPos()
                    end

                    mon.write(ch)
                    mon.setCursorPos(x + 1, y)
                end

                i = i + 1
            end
        end)
    end
end

print = function(...)
    nativePrint(...)

    local parts = {}
    local argc = select("#", ...)

    for i = 1, argc do
        parts[#parts + 1] = tostring(select(i, ...))
    end

    mirrorWriteRaw(table.concat(parts, "\t") .. "\n")
end

write = function(value)
    nativeWrite(value)
    mirrorWriteRaw(tostring(value or ""))
end

