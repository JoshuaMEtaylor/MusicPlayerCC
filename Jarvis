local function reportHeader(title)
    print("")
    print("============================================================")
    print(tostring(title or "SPEAKER REPORT"))
    print("============================================================")
end

local function makeSilentProbeBuffer()
    local buffer = {}
    for i = 1, 4096 do
        buffer[i] = 0
    end
    return buffer
end


local function makeAudibleToneBuffer(freq, seconds)
    -- Real audible square-wave buffer for speaker.playAudio.
    -- This is not a silent ping. If the speaker/player/chunk can output audio,
    -- this should be heard as a clear tone.
    local sampleRate = 48000
    local duration = tonumber(seconds) or 0.45
    local count = math.floor(sampleRate * duration)
    local period = math.max(1, math.floor(sampleRate / (tonumber(freq) or SPEAKER_AUDIBLE_TEST_HZ)))
    local buffer = {}

    for i = 1, count do
        if (i % period) < (period / 2) then
            buffer[i] = 80
        else
            buffer[i] = -80
        end
    end

    return buffer
end

local function makeReportRows()
    scanSpeakers()

    local rows = {}
    for i, item in ipairs(citySpeakers) do
        rows[#rows + 1] = {
            index = i,
            name = tostring(item.name),
            status = "PENDING",
            details = "waiting",
        }
    end
    return rows
end

local function updateReportRow(rows, name, status, details)
    for _, row in ipairs(rows or {}) do
        if tostring(row.name) == tostring(name) then
            row.status = status or row.status
            row.details = details or row.details
            return true
        end
    end
    return false
end

local function reportCounts(rows)
    local pass, fail, unknown, pending = 0, 0, 0, 0

    for _, row in ipairs(rows or {}) do
        if row.status == "PASS" then pass = pass + 1
        elseif row.status == "FAIL" then fail = fail + 1
        elseif row.status == "UNKNOWN" then unknown = unknown + 1
        else pending = pending + 1 end
    end

    return pass, fail, unknown, pending
end

local function reportSummaryText(rows)
    local pass, fail, unknown, pending = reportCounts(rows)
    return "SUMMARY: PASS=" .. tostring(pass) ..
        " FAIL=" .. tostring(fail) ..
        " UNKNOWN=" .. tostring(unknown) ..
        " PENDING=" .. tostring(pending)
end

local function printReportTable(title, rows, note)
    reportHeader(title)

    if note and note ~= "" then
        print(tostring(note))
        print("")
    end

    print(reportSummaryText(rows))
    print("")
    print("No  Speaker              Status    Details")
    print("--  -------------------  --------  -----------------------------")

    for _, row in ipairs(rows or {}) do
        local n = tostring(row.index or "?")
        if #n < 2 then n = " " .. n end

        local name = tostring(row.name or "?")
        if #name > 19 then name = name:sub(1, 19) end
        while #name < 19 do name = name .. " " end

        local status = tostring(row.status or "PENDING")
        while #status < 8 do status = status .. " " end

        local details = tostring(row.details or "")
        if #details > 29 then details = details:sub(1, 29) end

        print(n .. "  " .. name .. "  " .. status .. "  " .. details)
    end

    print("============================================================")
    print("")
end

local function speakerPassFailReport(title, audible)
    local rows = makeReportRows()

    if #rows == 0 then
        printReportTable(title or "SPEAKER TEST REPORT", rows, "No speakers are visible.")
        return false, rows
    end

    if audible then
        printReportTable(title or "SPEAKER REAL AUDIO REPORT", rows, "Sending REAL audible tone buffer to every speaker.")
    else
        printReportTable(title or "SPEAKER PING REPORT", rows, "Sending silent buffer handshake to every speaker.")
    end

    -- Clear all current speaker buffers first.
    for _, item in ipairs(citySpeakers) do
        pcall(function()
            item.speaker.stop()
        end)
    end

    sleep(0.25)

    local pending = {}
    local pendingCount = 0
    local buffer

    if audible then
        buffer = makeAudibleToneBuffer(SPEAKER_AUDIBLE_TEST_HZ, 0.45)
    else
        buffer = makeSilentProbeBuffer()
    end

    for _, row in ipairs(rows) do
        pending[row.name] = true
        pendingCount = pendingCount + 1
    end

    for _, item in ipairs(citySpeakers) do
        local name = tostring(item.name)

        local ok, accepted = pcall(function()
            return item.speaker.playAudio(buffer, audible and SPEAKER_AUDIBLE_TEST_VOLUME or 1)
        end)

        if ok and accepted then
            if audible then
                updateReportRow(rows, name, "UNKNOWN", "tone accepted; waiting")
            else
                updateReportRow(rows, name, "UNKNOWN", "accepted; waiting empty")
            end
        elseif ok and not accepted then
            updateReportRow(rows, name, "FAIL", "rejected/buffer full")
            if pending[name] then
                pending[name] = nil
                pendingCount = pendingCount - 1
            end
        else
            updateReportRow(rows, name, "FAIL", "error: " .. tostring(accepted))
            if pending[name] then
                pending[name] = nil
                pendingCount = pendingCount - 1
            end
        end
    end

    if audible then
        printReportTable(title or "SPEAKER REAL AUDIO REPORT", rows, "Tone sent. Waiting for speaker_audio_empty replies...")
    else
        printReportTable(title or "SPEAKER PING REPORT", rows, "Probe sent. Waiting for speaker_audio_empty replies...")
    end

    local timer = os.startTimer(SPEAKER_TEST_TIMEOUT or 8)

    while pendingCount > 0 do
        local event, p1 = os.pullEvent()

        if event == "speaker_audio_empty" then
            if p1 == nil then
                for name, stillPending in pairs(pending) do
                    if stillPending then
                        updateReportRow(rows, name, "UNKNOWN", "empty event unnamed")
                    end
                end
                pendingCount = 0
                break
            end

            local name = tostring(p1)

            if pending[name] then
                pending[name] = nil
                pendingCount = pendingCount - 1

                if audible then
                    updateReportRow(rows, name, "PASS", "real tone accepted+drained")
                else
                    updateReportRow(rows, name, "PASS", "accepted + drained")
                end
            end

        elseif event == "timer" and p1 == timer then
            for name, stillPending in pairs(pending) do
                if stillPending then
                    updateReportRow(rows, name, "FAIL", "timeout/no drain event")
                end
            end
            pendingCount = 0
            break

        elseif event == "peripheral" or event == "peripheral_detach" then
            for name, stillPending in pairs(pending) do
                if stillPending then
                    updateReportRow(rows, name, "UNKNOWN", "network changed")
                end
            end
            pendingCount = 0
            break
        end
    end

    local pass, fail, unknown, pend = reportCounts(rows)
    local clean = fail == 0 and unknown == 0 and pend == 0

    local finalNote
    if audible then
        finalNote = clean and
            "RESULT: SOFTWARE CLEAN PASS. If a physical area is silent, CC accepted audio but Minecraft/client/chunk audibility is failing there." or
            "RESULT: NOT CLEAN - see FAIL/UNKNOWN rows."
    else
        finalNote = clean and
            "RESULT: CLEAN PASS" or
            "RESULT: NOT CLEAN - see FAIL/UNKNOWN rows."
    end

    printReportTable(title or "SPEAKER TEST FINAL REPORT", rows, finalNote)

    return clean, rows
end

