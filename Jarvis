local citySpeakers = {}

local function peripheralIsSpeaker(name)
    if not name then return false end

    if peripheral.hasType then
        local ok, result = pcall(function()
            return peripheral.hasType(name, "speaker")
        end)
        if ok and result == true then return true end
    end

    local pType = peripheral.getType(name)

    if pType == "speaker" then return true end

    if type(pType) == "table" then
        for _, t in ipairs(pType) do
            if t == "speaker" then return true end
        end
    end

    return false
end

local function scanSpeakers()
    citySpeakers = {}

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralIsSpeaker(name) then
            local wrapped = peripheral.wrap(name)

            if wrapped and wrapped.playAudio then
                citySpeakers[#citySpeakers + 1] = {
                    name = name,
                    speaker = wrapped,
                    type = peripheral.getType(name),
                    disabled = isSpeakerDisabled(name),
                }
            end
        end
    end

    table.sort(citySpeakers, function(a, b)
        return tostring(a.name) < tostring(b.name)
    end)

    return #citySpeakers
end

local function speakerCount()
    return #citySpeakers
end

local function activeSpeakers()
    local list = {}

    for _, item in ipairs(citySpeakers) do
        if FORCE_ALL_VISIBLE_SPEAKERS or not isSpeakerDisabled(item.name) then
            list[#list + 1] = item
        end
    end

    return list
end

local function activeSpeakerCount()
    local count = 0

    for _, item in ipairs(citySpeakers) do
        if FORCE_ALL_VISIBLE_SPEAKERS or not isSpeakerDisabled(item.name) then
            count = count + 1
        end
    end

    return count
end

local function resolveSpeakerRef(ref)
    ref = trim(ref or "")

    if ref == "" then return nil, "No speaker reference supplied." end

    local asNumber = tonumber(ref)
    if asNumber and citySpeakers[asNumber] then
        return citySpeakers[asNumber]
    end

    for _, item in ipairs(citySpeakers) do
        if tostring(item.name) == ref then
            return item
        end
    end

    return nil, "No visible speaker matches '" .. tostring(ref) .. "'."
end


