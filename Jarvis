local function waitForSpeakerEmpty(speakerName, timeoutSeconds, shouldContinue)
    local timer = os.startTimer(timeoutSeconds or SPEAKER_ORDERED_SEND_TIMEOUT)

    while true do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        local event, p1 = os.pullEvent()

        if event == "speaker_audio_empty" then
            if p1 == nil or tostring(p1) == tostring(speakerName) then
                return true
            end

        elseif event == "timer" and p1 == timer then
            return false, "timeout waiting for " .. tostring(speakerName)

        elseif event == "peripheral_detach" then
            return false, "peripheral detached while waiting for " .. tostring(speakerName)
        end
    end
end

local function playAudioBufferOnSpeaker(item, buffer, volume, debug, shouldContinue)
    local name = tostring(item.name)
    local retries = 0

    while true do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        retries = retries + 1

        local ok, accepted = pcall(function()
            return item.speaker.playAudio(buffer, volume or 1)
        end)

        if ok and accepted then
            if debug then
                print("[AUDIO] " .. name .. " accepted")
            end
            return true
        end

        if not ok then
            return false, "playAudio error on " .. name .. ": " .. tostring(accepted)
        end

        if retries >= SPEAKER_ORDERED_MAX_RETRIES then
            return false, "too many retries sending to " .. name
        end

        -- Buffer-full is normal during continuous audio. Wait for THIS speaker
        -- to request the next buffer. This preserves smooth audio for active speakers.
        if debug then
            print("[AUDIO] " .. name .. " buffer full; waiting for empty")
        end

        local waited, waitErr = waitForSpeakerEmpty(name, SPEAKER_ORDERED_SEND_TIMEOUT, shouldContinue)
        if not waited then
            return false, waitErr
        end
    end
end

local function playAudioBufferOnAll(buffer, volume, debug, shouldContinue)
    -- Smooth active-only ordered broadcast:
    -- dead speakers should be manually removed with spdrop.
    -- active speakers receive every buffer continuously.
    local targets = activeBroadcastSpeakers()

    if #targets == 0 then
        return false, "No active broadcast speakers. Run spresume or spuse <speaker>."
    end

    if debug then
        print("[AUDIO] Smooth ordered broadcast to " .. tostring(#targets) .. "/" .. tostring(#citySpeakers) .. " speaker(s).")
    end

    for _, item in ipairs(targets) do
        local ok, err = playAudioBufferOnSpeaker(item, buffer, volume, debug, shouldContinue)
        if not ok then
            return false, err
        end
    end

    return true
end

local function playOnAllSpeakers(sound, volume, pitch)
    local targets = activeBroadcastSpeakers()

    if #targets == 0 then
        print("No active broadcast speakers.")
        return false, 0
