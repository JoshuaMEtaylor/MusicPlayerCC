            ["User-Agent"] = "CC-Tweaked-JARVIS-Legacy-TTS",
        }, true)

        if not response then error("Legacy TTS HTTP request failed.") end

        local chunks = 0
        local bytes = 0

        while true do
            local chunk = response.read(LEGACY_TTS_CHUNK_SIZE)
            if not chunk then break end

            chunks = chunks + 1
            bytes = bytes + #chunk

            if debug and chunks == 1 then
                print("[TTS] Legacy first audio chunk: " .. tostring(#chunk) .. " bytes.")
            end

            local audio = decoder(chunk)
            local played, playErr = playAudioBufferOnAll(audio, TTS_VOLUME, debug, nil)

            if not played then
                response.close()
                error(playErr or "Speaker playback failed.")
            end
        end

        response.close()

        if debug then
            print("[TTS] Legacy chunks: " .. tostring(chunks) .. " | Bytes: " .. tostring(bytes))
        end

        if chunks == 0 then error("Legacy TTS returned zero audio chunks.") end
    end)

    if not ok then return false, tostring(err) end
    return true, "spoken"
