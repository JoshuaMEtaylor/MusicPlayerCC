local function roughCjkByteCount(text)
    text = tostring(text or "")
    local count = 0

    for i = 1, #text do
        local b = text:byte(i)

        -- Most common CJK UTF-8 leading bytes land here.
        if b and b >= 0xE4 and b <= 0xE9 then
            count = count + 1
        end
    end

    return count
end

local function looksLikeMandarinBroadcast(text)
    text = trim(text or "")

    if text == "" then return false end
    if hasLatinLetters(text) then return false end
    if roughCjkByteCount(text) < 18 then return false end

    return true
end

