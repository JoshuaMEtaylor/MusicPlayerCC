math.randomseed(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))

loadDroppedSpeakers()
startMonitorMirror()
openAllPaModems()

print("Scanning wired speaker network...")
local foundSpeakers = scanSpeakers()
print("Speaker scan complete: " .. tostring(foundSpeakers) .. " speaker(s) visible.")
sleep(0.5)

local ok, err = pcall(function()
    parallel.waitForAny(chatLoop, morningBroadcastLoop)
end)

if not ok then
    term.setTextColor(colors.red)
    print("JARVIS error: " .. s(err))
    term.setTextColor(colors.white)
end
