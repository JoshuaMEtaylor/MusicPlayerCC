local function resolveSpeakerRef(ref)
    scanSpeakers()

    ref = trim(ref or "")

    if ref == "" then
        return nil, "No speaker reference supplied."
    end

    local n = tonumber(ref)
    if n and citySpeakers[n] then
        return citySpeakers[n], nil
    end

    for _, item in ipairs(citySpeakers) do
        if tostring(item.name) == ref then
            return item, nil
        end
    end

    return nil, "No visible speaker matches '" .. tostring(ref) .. "'."
end

local function dropSpeaker(ref)
