    if verbose then
        print("[AUDIO] Hard stop " .. tostring(reason or "") .. " across " .. tostring(#citySpeakers) .. " visible speaker(s).")
    end

    for pass = 1, HARD_STOP_PASSES do
        for _, item in ipairs(citySpeakers) do
            local ok = pcall(function()
                item.speaker.stop()
            end)

            if ok and pass == 1 then
                count = count + 1
            end
        end

        sleep(HARD_STOP_GAP)
    end

    os.queueEvent("jarvis_audio_reset")

    if verbose then
        print("[AUDIO] Hard stop reached " .. tostring(count) .. " speaker(s).")
    end

    return count
end

