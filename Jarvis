local function cleanSpeechText(text)
    text = s(text)
    text = text:gsub("[\r\n]+", ". ")
    text = text:gsub("[%{%}%[%]\"_=<>|`#*]", " ")
    text = text:gsub("%s+", " ")
    text = trim(text)

    if #text > TTS_TOTAL_MAX_CHARS then
        text = text:sub(1, TTS_TOTAL_MAX_CHARS) .. "..."
    end

    return text
end

local function splitSpeechChunks(text)
    local cleaned = cleanSpeechText(text)
    local chunks = {}

    if cleaned == "" or cleaned == "nil" then return chunks end

    while #cleaned > TTS_SINGLE_REQUEST_MAX_CHARS do
        local head = cleaned:sub(1, TTS_SINGLE_REQUEST_MAX_CHARS)
        local cut = nil

        for i = #head, 1, -1 do
            local ch = head:sub(i, i)
            if ch == "." or ch == "!" or ch == "?" or ch == ";" or ch == ":" then
                cut = i
                break
            end
        end

        if not cut or cut < 60 then
            for i = #head, 1, -1 do
                if head:sub(i, i) == " " then
                    cut = i
                    break
                end
            end
        end

        if not cut or cut < 30 then cut = TTS_SINGLE_REQUEST_MAX_CHARS end

        local chunk = trim(cleaned:sub(1, cut))
        if chunk ~= "" then chunks[#chunks + 1] = chunk end

        cleaned = trim(cleaned:sub(cut + 1))
    end

    if cleaned ~= "" then chunks[#chunks + 1] = cleaned end

    return chunks
end

local function speakOneChunkToCity(cleaned, debug, chunkIndex, chunkCount)
    if debug then
        print("[TTS] Requesting chunk " .. tostring(chunkIndex) .. "/" .. tostring(chunkCount) .. " (" .. tostring(#cleaned) .. " chars)...")
    end

    local ok, err = pcall(function()
        local dfpwm = require("cc.audio.dfpwm")
        local decoder = dfpwm.make_decoder()

        local url = TTS_URL_BASE .. textutils.urlEncode(cleaned)
        local response = http.get(url, {
            ["User-Agent"] = "CC-Tweaked-JARVIS-TTS",
        }, true)

        if not response then error("TTS HTTP request failed.") end

        local code = "?"
        if response.getResponseCode then
            local okCode, c = pcall(function() return response.getResponseCode() end)
            if okCode then code = tostring(c) end
        end

        if debug then print("[TTS] HTTP " .. tostring(code)) end

        local chunks = 0
        local bytes = 0

        while true do
            local chunk = response.read(TTS_CHUNK_SIZE)
            if not chunk then break end

            chunks = chunks + 1
            bytes = bytes + #chunk

            if debug and chunks == 1 then
                print("[TTS] First audio chunk: " .. tostring(#chunk) .. " bytes.")
            end

            local audio = decoder(chunk)
            local played, playErr = playAudioBufferOnAll(audio, TTS_VOLUME, debug, nil)

            if not played then
                response.close()
                error(playErr or "Speaker playback failed.")
            end
        end

        response.close()

        if debug then
            print("[TTS] Audio chunks: " .. tostring(chunks) .. " | Bytes: " .. tostring(bytes))
        end

        if chunks == 0 then error("TTS returned zero audio chunks.") end
    end)

    if not ok then return false, tostring(err) end
    return true, "spoken"
end

local function speakToCity(text, debug)
    if debug then print("[TTS] Requested.") end

    if not TTS_ENABLED then return false, "TTS disabled." end
    if not http or not http.get then return false, "HTTP unavailable for TTS." end

    scanSpeakers()

    if debug then print("[TTS] Speakers visible: " .. tostring(#citySpeakers)) end
    if #citySpeakers == 0 then return false, "No visible speaker peripherals." end

    local chunks = splitSpeechChunks(text)
    if #chunks == 0 then return false, "Nothing to speak." end

    if debug then
        local total = 0
        for _, c in ipairs(chunks) do total = total + #c end
        print("[TTS] Split into " .. tostring(#chunks) .. " request(s), " .. tostring(total) .. " chars total.")
    end

    for i, chunk in ipairs(chunks) do
        local ok, err = speakOneChunkToCity(chunk, debug, i, #chunks)
        if not ok then return false, err end
        if i < #chunks then sleep(0.15) end
    end

    return true, "spoken"
end

local function speakAsync(text)
    local payload = tostring(text or "")

    pcall(function()
        parallel.waitForAny(
            function()
                local ok, err = speakToCity(payload, false)
                if not ok then print("TTS warning: " .. tostring(err)) end
            end,
            function()
                sleep(30)
                print("TTS timeout.")
            end
        )
    end)
end

