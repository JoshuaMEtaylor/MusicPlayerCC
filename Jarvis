local function selfUpdate()
    if not UPDATE_ENABLED then return end

    if hasArg(UPDATE_SKIP_ARG) then
        print("Auto-update skipped for freshly relaunched copy.")
        return
    end

    if not http or not http.get then
        print("HTTP unavailable. Skipping update.")
        return
    end

    if not shell or not shell.run then
        print("Shell API unavailable. Skipping update.")
        return
    end

    if not UPDATE_URL or UPDATE_URL == "" then
        print("No UPDATE_URL set. Skipping update.")
        return
    end

    local program = shell.getRunningProgram and shell.getRunningProgram() or "Jarvis"
    if not program or program == "" then program = "Jarvis" end

    print("[ JARVIS Town Broadcast Core ]")
    print("Checking GitHub update...")

    local tmp = program .. ".new"
    local old = program .. ".old"
    fs.delete(tmp)

    local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
    local sep = UPDATE_URL:find("?", 1, true) and "&" or "?"
    local url = UPDATE_URL .. sep .. "cb=" .. cb

    local handle = http.get(url, {
        ["User-Agent"] = "CC-Tweaked-JARVIS-Town-Broadcast-Updater",
        ["Cache-Control"] = "no-cache",
    })

    if not handle then
        print("Update failed: no HTTP response. Keeping local copy.")
        sleep(0.5)
        return
    end

    local body = handle.readAll()
    handle.close()

    local okDownload =
        body and
        #body > 1000 and
        not body:find("404: Not Found", 1, true) and
        not body:find("<!DOCTYPE html", 1, true) and
        not body:find("<html", 1, true)

    if not okDownload then
        fs.delete(tmp)
        print("Update rejected: empty, invalid, or not raw Lua. Keeping local copy.")
        sleep(0.5)
        return
    end

    local f = fs.open(tmp, "w")
    if not f then
        print("Could not write temporary update file. Keeping local copy.")
        return
    end

    f.write(body)
    f.close()

    fs.delete(old)
    if fs.exists(program) then fs.move(program, old) end
    fs.move(tmp, program)

    print("Updated. Relaunching...")
    sleep(0.5)

    local relaunch = { program, UPDATE_SKIP_ARG }
    for i = 1, #args do
        if tostring(args[i]) ~= UPDATE_SKIP_ARG then
            relaunch[#relaunch + 1] = tostring(args[i])
        end
    end

    local unpackFn = table.unpack or unpack
    shell.run(unpackFn(relaunch))
    return "updated"
end

local updateResult = selfUpdate()
if updateResult == "updated" then return end

