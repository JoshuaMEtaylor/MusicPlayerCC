local function makeTrackUrl(fileName)
    return MUSIC_RAW_BASE .. encodePath(fileName)
end

local function loadTracksFromGitHub()
    if not http or not http.get then
        return false, "HTTP unavailable."
    end

    print("[MUSIC] Loading track list from GitHub...")

    local handle = http.get(MUSIC_API_URL, {
        ["User-Agent"] = "CC-Tweaked-JARVIS-Music",
        ["Accept"] = "application/vnd.github+json",
    })

    if not handle then
        return false, "Could not contact GitHub contents API."
    end

    local code = "?"
    if handle.getResponseCode then
        local okCode, c = pcall(function() return handle.getResponseCode() end)
        if okCode then code = tostring(c) end
    end

    local body = handle.readAll()
    handle.close()

    print("[MUSIC] GitHub API HTTP " .. tostring(code))

    local data = textutils.unserializeJSON(body)
    if type(data) ~= "table" then
        return false, "Could not parse GitHub track list JSON."
    end

    local found = {}

    for _, item in ipairs(data) do
        if type(item) == "table" and item.type == "file" and type(item.name) == "string" then
            if item.name:lower():match("%.dfpwm$") then
                found[#found + 1] = {
                    file = item.name,
                    name = niceTrackName(item.name),
                    size = tonumber(item.size) or 0,
                    url = makeTrackUrl(item.name),
                }
            end
        end
    end

    table.sort(found, function(a, b)
        return tostring(a.name):lower() < tostring(b.name):lower()
    end)

    musicTracks = found

    if #musicTracks == 0 then
        return false, "No .dfpwm tracks found in the music repo root."
    end

    return true, #musicTracks
end

local function ensureTracks()
    if #musicTracks > 0 then return true, #musicTracks end
    return loadTracksFromGitHub()
end

local function printTracks()
    local ok, result = ensureTracks()

    print("")
    line()
    print("APPROVED MUSIC TRACKS")
    print("Repo: " .. MUSIC_REPO_USER .. "/" .. MUSIC_REPO_NAME)
    print("")

    if not ok then
        print("Failed: " .. tostring(result))
    else
        for i, track in ipairs(musicTracks) do
            local sizeKb = track.size and math.floor(track.size / 1024) or 0
            print(tostring(i) .. ". " .. tostring(track.name) .. " [" .. tostring(sizeKb) .. "KB]")
