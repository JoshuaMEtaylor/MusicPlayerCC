local function requestMusic(track)
    if not track then
        print("[MUSIC] No track selected.")
        return false
    end

    musicState.stop = false
    musicState.playing = true
    musicState.token = musicState.token + 1
    musicState.current = track

    print("[MUSIC] Queued: " .. tostring(track.name))
    os.queueEvent("jarvis_music_wake")
    return true
end

local function playRandomMusic()
    local ok, result = ensureTracks()

    if not ok then
        print("[MUSIC] Track load failed: " .. tostring(result))
        return false
    end

    if #musicTracks == 0 then
        print("[MUSIC] No tracks loaded.")
        return false
    end

    local track = musicTracks[math.random(1, #musicTracks)]
    print("Daily music selection: " .. tostring(track.name))
    return requestMusic(track)
end

local function musicLoop()
    while true do
        os.pullEvent("jarvis_music_wake")

        while musicState.playing and musicState.current do
            local track = musicState.current
            local token = musicState.token

            print("[MUSIC] Opening stream: " .. tostring(track.name))

            local handle = http.get(track.url, {
                ["User-Agent"] = "CC-Tweaked-JARVIS-Music",
            }, true)

            if not handle then
                print("[MUSIC] Stream failed: no HTTP handle.")
                musicState.playing = false
                break
            end

            local code = "?"
            if handle.getResponseCode then
                local okCode, c = pcall(function() return handle.getResponseCode() end)
                if okCode then code = tostring(c) end
            end
            print("[MUSIC] Stream HTTP " .. tostring(code))

            local okPlay, errPlay = pcall(function()
                local dfpwm = require("cc.audio.dfpwm")
                local decoder = dfpwm.make_decoder()
                local chunks = 0
                local bytes = 0

                while musicState.playing and not musicState.stop and token == musicState.token do
                    local chunk = handle.read(MUSIC_CHUNK_SIZE)
                    if not chunk then break end

                    chunks = chunks + 1
                    bytes = bytes + #chunk

                    if chunks == 1 then
                        print("[MUSIC] First audio chunk: " .. tostring(#chunk) .. " bytes.")
                    end

                    local audio = decoder(chunk)

                    local played, playErr = playAudioBufferOnAll(audio, MUSIC_VOLUME, false, function()
                        return musicState.playing and not musicState.stop and token == musicState.token
                    end)

                    if not played and playErr ~= "cancelled" then
                        error(playErr or "speaker playback failed")
                    end
                end

                print("[MUSIC] Finished/ended. Chunks=" .. tostring(chunks) .. " Bytes=" .. tostring(bytes))
            end)

            handle.close()

            if not okPlay then
                print("[MUSIC] Playback error: " .. tostring(errPlay))
            end

            if token == musicState.token then
                musicState.playing = false
                musicState.stop = false
            end
        end
    end
end

-- =============================================================================
-- TTS OVER WIRED SPEAKER NETWORK
-- OpenAI speech endpoint returns raw PCM: 24kHz, 16-bit signed little-endian.
-- CC speakers expect 48kHz 8-bit signed sample buffers, so this code:
--   1. reads OpenAI PCM bytes,
--   2. converts 16-bit signed samples to 8-bit signed samples,
--   3. duplicates each sample to upsample 24kHz -> 48kHz,
--   4. sends the resulting buffer to every visible wired speaker.
-- =============================================================================

local function cleanSpeechText(text)
    text = s(text)
    text = text:gsub("[\r\n]+", ". ")
    text = text:gsub("[%{%}%[%]\"_=<>|`#*]", " ")
    text = text:gsub("%s+", " ")
    text = trim(text)

    if #text > TTS_TOTAL_MAX_CHARS then
        text = text:sub(1, TTS_TOTAL_MAX_CHARS) .. "..."
    end

    return text
end

local function utf8SafeCutByte(str, maxBytes)
    if #str <= maxBytes then return #str end

    local cut = maxBytes

    -- Move left until the next byte begins a new UTF-8 character.
    while cut > 1 do
        local nextByte = str:byte(cut + 1)

        if not nextByte then
            break
        end

        -- UTF-8 continuation bytes are 128-191.
        if nextByte < 128 or nextByte >= 192 then
            break
        end

        cut = cut - 1
    end

    if cut < 1 then cut = maxBytes end
    return cut
end

local function splitSpeechChunks(text)
    local cleaned = cleanSpeechText(text)
    local chunks = {}

    if cleaned == "" or cleaned == "nil" then return chunks end

    while #cleaned > TTS_SINGLE_REQUEST_MAX_CHARS do
        local safeMax = utf8SafeCutByte(cleaned, TTS_SINGLE_REQUEST_MAX_CHARS)
        local head = cleaned:sub(1, safeMax)
        local cut = nil

        -- Prefer sentence boundaries. Includes English and Chinese punctuation.
        local boundary = head:match("^(.*[%.%!%?%;%:%。%！%？%；%：])")
        if boundary and #boundary >= 120 then
            cut = #boundary
        end

        -- Fallback to the last space.
        if not cut then
            for i = #head, 1, -1 do
                if head:sub(i, i) == " " then
                    cut = i
                    break
                end
            end
        end

        if not cut or cut < 80 then cut = #head end

        -- Ensure the chosen cut does not split a UTF-8 character.
        cut = utf8SafeCutByte(cleaned, cut)

        local chunk = trim(cleaned:sub(1, cut))
        if chunk ~= "" then chunks[#chunks + 1] = chunk end

        cleaned = trim(cleaned:sub(cut + 1))
    end

    if cleaned ~= "" then chunks[#chunks + 1] = cleaned end

    return chunks
end

local function pcm16leToSpeakerBuffer(chunk, carryByte)
    local out = {}
    local i = 1

    if carryByte ~= nil then
        if #chunk >= 1 then
            local lo = carryByte
            local hi = chunk:byte(1)
            local value = lo + hi * 256
            if value >= 32768 then value = value - 65536 end

            local sample = math.floor(value / 256)
            if sample < -128 then sample = -128 end
            if sample > 127 then sample = 127 end

            out[#out + 1] = sample
            out[#out + 1] = sample

            carryByte = nil
            i = 2
        else
            return out, carryByte
        end
    end

    while i + 1 <= #chunk do
        local lo = chunk:byte(i)
        local hi = chunk:byte(i + 1)

        local value = lo + hi * 256
        if value >= 32768 then value = value - 65536 end

        local sample = math.floor(value / 256)
        if sample < -128 then sample = -128 end
        if sample > 127 then sample = 127 end

        -- OpenAI PCM is 24kHz. Duplicate each sample for CC's 48kHz speaker.
        out[#out + 1] = sample
        out[#out + 1] = sample

        i = i + 2
    end

    if i <= #chunk then
        carryByte = chunk:byte(i)
    end

    return out, carryByte
end

local function speakOneChunkOpenAI(cleaned, debug, chunkIndex, chunkCount, ttsInstructions)
    if debug then
        print("[TTS] OpenAI chunk " .. tostring(chunkIndex) .. "/" .. tostring(chunkCount) .. " (" .. tostring(#cleaned) .. " chars).")
        print("[TTS] Voice: " .. tostring(OPENAI_TTS_VOICE) .. " | Model: " .. tostring(OPENAI_TTS_MODEL))
    end

    local body = textutils.serializeJSON({
        model = OPENAI_TTS_MODEL,
        voice = OPENAI_TTS_VOICE,
        input = cleaned,
        instructions = ttsInstructions or OPENAI_TTS_INSTRUCTIONS,
        response_format = OPENAI_TTS_RESPONSE_FORMAT,
        speed = OPENAI_TTS_SPEED,
    })

    local response = http.post(
        OPENAI_TTS_URL,
        body,
        {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. API_KEY,
            ["User-Agent"] = "CC-Tweaked-JARVIS-OpenAI-TTS",
        },
        true
    )

    if not response then
        return false, "OpenAI TTS HTTP request failed."
    end

    local code = 200
    if response.getResponseCode then
        local okCode, c = pcall(function() return response.getResponseCode() end)
        if okCode and c then code = tonumber(c) or c end
    end

    if debug then print("[TTS] OpenAI HTTP " .. tostring(code)) end

    if tostring(code) ~= "200" then
        local errBody = ""
        pcall(function() errBody = response.readAll() or "" end)
        response.close()
        return false, "OpenAI TTS HTTP " .. tostring(code) .. ": " .. tostring(errBody):sub(1, 240)
    end

    local ok, err = pcall(function()
        local chunks = 0
        local bytes = 0
        local carryByte = nil

        while true do
            local raw = response.read(OPENAI_TTS_PCM_CHUNK_SIZE)
            if not raw then break end

            chunks = chunks + 1
            bytes = bytes + #raw

            if debug and chunks == 1 then
                print("[TTS] First PCM chunk: " .. tostring(#raw) .. " bytes.")
            end

            local audio
            audio, carryByte = pcm16leToSpeakerBuffer(raw, carryByte)

            if #audio > 0 then
                local played, playErr = playAudioBufferOnAll(audio, TTS_VOLUME, debug, nil)
                if not played then
                    error(playErr or "Speaker playback failed.")
                end
            end
        end

        if debug then
            print("[TTS] PCM chunks: " .. tostring(chunks) .. " | Bytes: " .. tostring(bytes))
        end

        if chunks == 0 then
            error("OpenAI TTS returned zero PCM chunks.")
        end
    end)

    response.close()

    if not ok then
        return false, tostring(err)
    end

    return true, "spoken"
end

local function speakOneChunkLegacy(cleaned, debug, chunkIndex, chunkCount)
    if debug then
        print("[TTS] Legacy fallback chunk " .. tostring(chunkIndex) .. "/" .. tostring(chunkCount) .. " (" .. tostring(#cleaned) .. " chars).")
    end

    local ok, err = pcall(function()
        local dfpwm = require("cc.audio.dfpwm")
        local decoder = dfpwm.make_decoder()

        local url = LEGACY_TTS_URL_BASE .. textutils.urlEncode(cleaned)
        local response = http.get(url, {
            ["User-Agent"] = "CC-Tweaked-JARVIS-Legacy-TTS",
        }, true)

        if not response then error("Legacy TTS HTTP request failed.") end

        local chunks = 0
        local bytes = 0

        while true do
            local chunk = response.read(LEGACY_TTS_CHUNK_SIZE)
            if not chunk then break end

            chunks = chunks + 1
            bytes = bytes + #chunk

            if debug and chunks == 1 then
                print("[TTS] Legacy first audio chunk: " .. tostring(#chunk) .. " bytes.")
            end

            local audio = decoder(chunk)
            local played, playErr = playAudioBufferOnAll(audio, TTS_VOLUME, debug, nil)

            if not played then
                response.close()
                error(playErr or "Speaker playback failed.")
            end
        end

        response.close()

        if debug then
            print("[TTS] Legacy chunks: " .. tostring(chunks) .. " | Bytes: " .. tostring(bytes))
        end

        if chunks == 0 then error("Legacy TTS returned zero audio chunks.") end
    end)

    if not ok then return false, tostring(err) end
    return true, "spoken"
end

local function speakOneChunkToCity(cleaned, debug, chunkIndex, chunkCount, ttsInstructions)
    if TTS_PROVIDER == "openai" then
        local ok, err = speakOneChunkOpenAI(cleaned, debug, chunkIndex, chunkCount, ttsInstructions)
        if ok then return true, "spoken" end

        if debug then print("[TTS] OpenAI failed: " .. tostring(err)) end

        if LEGACY_TTS_FALLBACK_ENABLED then
            if debug then print("[TTS] Trying legacy fallback.") end
            return speakOneChunkLegacy(cleaned, debug, chunkIndex, chunkCount)
        end

        return false, err
    end

    return speakOneChunkLegacy(cleaned, debug, chunkIndex, chunkCount)
end

local function speakToCity(text, debug, ttsInstructions)
    if debug then print("[TTS] Requested.") end

    if not TTS_ENABLED then return false, "TTS disabled." end
    if not http or not http.get or not http.post then return false, "HTTP unavailable for TTS." end

    scanSpeakers()

    if debug then print("[TTS] Speakers visible: " .. tostring(#citySpeakers)) end
    if #citySpeakers == 0 then return false, "No visible speaker peripherals." end

    local chunks = splitSpeechChunks(text)
    if #chunks == 0 then return false, "Nothing to speak." end

    if debug then
        local total = 0
        for _, c in ipairs(chunks) do total = total + #c end
        print("[TTS] Provider: " .. tostring(TTS_PROVIDER))
        print("[TTS] Split into " .. tostring(#chunks) .. " request(s), " .. tostring(total) .. " chars total.")
    end

    for i, chunk in ipairs(chunks) do
        local ok, err = speakOneChunkToCity(chunk, debug, i, #chunks, ttsInstructions)
        if not ok then return false, err end
        if i < #chunks then sleep(0.12) end
    end

    return true, "spoken"
end

local function speakAsync(text, ttsInstructions)
    local payload = tostring(text or "")

    pcall(function()
        parallel.waitForAny(
            function()
                local ok, err = speakToCity(payload, false, ttsInstructions)
                if not ok then print("TTS warning: " .. tostring(err)) end
            end,
            function()
                sleep(45)
                print("TTS timeout.")
            end
        )
    end)
end

