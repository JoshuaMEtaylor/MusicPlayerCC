-- =============================================================================
-- JARVIS BASE CORE + MORNING STATE BROADCAST
-- Minimal ComputerCraft OpenAI chat client
--
-- Keeps:
--   - safe GitHub self-updater
--   - API key loading via require("JarvisKey")
--   - OpenAI request
--   - simple chat console loop
--   - once-per-Minecraft-day morning patriotic radio-style address
--
-- Removed:
--   - turtle/squad/fleet code
--   - GPS/network inboxes
--   - old databanks
--   - monitors
--   - TTS
--   - environment scanning
--   - local Lua execution tools
--
-- Required file:
--   JarvisKey.lua
--
-- Supported JarvisKey.lua formats:
--
--   return "sk-..."
--
-- or:
--
--   return {
--     api_key = "sk-..."
--   }
--
-- or plain text:
--
--   sk-...
--
-- Normal run:
--   Jarvis
--
-- Manual bypass updater:
--   Jarvis --updated
--
-- Commands:
--   exit      - close JARVIS
--   clear     - clear chat history
--   raw       - show latest raw response file
--   time      - show Minecraft date/time
--   morning   - force a test morning broadcast
--   music     - remind/start attention toward daily music
--
-- IMPORTANT:
--   Change UPDATE_URL below to your raw GitHub URL once your new JARVIS repo/path exists.
-- =============================================================================

local VERSION = "1.1.0-base-morning-state-radio"
