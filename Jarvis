            elseif lower == "sptargets" or lower == "spquarantine" or lower == "spbad" then
                printBroadcastTargets()

            elseif lower == "spresume" or lower == "spclear" then
                clearDroppedSpeakers()

            elseif lower:match("^spdrop%s+") or lower:match("^speaker%s+drop%s+") then
                local ref =
                    input:match("^spdrop%s+(.+)$") or
                    input:match("^speaker%s+drop%s+(.+)$")
                dropSpeaker(ref)

            elseif lower:match("^spuse%s+") or lower:match("^speaker%s+use%s+") then
                local ref =
                    input:match("^spuse%s+(.+)$") or
                    input:match("^speaker%s+use%s+(.+)$")
                useSpeaker(ref)

            elseif lower == "peripherals" then
                printAllPeripherals()

            elseif lower == "monitors" or lower == "monitor" then
                refreshMonitorMirror()

            elseif lower == "montest" or lower == "mon test" then
                monitorMirrorTest()

            elseif lower == "version" then
                print("JARVIS version: " .. tostring(VERSION))
                print("Update URL: " .. tostring(UPDATE_URL))
                print("Normal chat language: English")
                print("Morning broadcast language: angry Mandarin only")
                print("TTS provider: " .. tostring(TTS_PROVIDER))
                print("OpenAI TTS voice: " .. tostring(OPENAI_TTS_VOICE))
                print("Speaker audio mode: hybrid direct wired + wireless speaker terminals")

            elseif lower == "update" or lower == "selfupdate" then
                print("Forcing GitHub self-update from:")
                print(UPDATE_URL)
                local result = selfUpdate(true)

                if result == "updated" then
                    return
                else
                    print("No update applied or update failed. Local copy kept.")
                end

            elseif lower == "testspk" then
                testSpeakers()

            elseif lower == "spping" or lower == "speakerping" or lower == "ping speakers" then
                speakerPingReportCommand()

            elseif lower == "sphear" or lower == "sptesthear" or lower == "speakeraudible" then
                speakerAudibleReportCommand()

            elseif lower == "spbeacon" or lower == "speakerbeacon" then
                speakerBeaconAll()

            elseif lower == "stopbeacon" or lower == "spstopbeacon" then
                stopSpeakerBeacon()

            elseif lower == "stopspk" then
                stopAllSpeakers()

            elseif lower == "tts on" then
                TTS_ENABLED = true
                print("TTS enabled.")
                speakAsync("Town broadcast voice enabled.")

            elseif lower == "tts off" then
                TTS_ENABLED = false
                print("TTS disabled.")

            elseif lower == "tts test" then
                local okSpeak, speakErr = speakToCity("JARVIS town broadcast voice online. Red and black banners stand ready under Ako.", true)
                if okSpeak then print("TTS test spoken.") else print("TTS test failed: " .. tostring(speakErr)) end

            elseif lower == "tts debug" then
                ttsDebug()

            elseif lower == "tts mandarin" then
                local sample = "全体市民肃静！赤黑旗帜已经升起，今日的秩序不容怠慢。阿科王朝要求生产、忠诚与服从。"
                local okSpeak, speakErr = speakToCity(sample, true, MORNING_TTS_INSTRUCTIONS)
                if okSpeak then print("Angry Mandarin TTS test spoken.") else print("Mandarin TTS test failed: " .. tostring(speakErr)) end

            elseif lower == "voices" then
                print("OpenAI voices to try:")
                print("  cedar  - authoritative / polished")
                print("  marin  - natural / high quality")
                print("  onyx   - deep / serious")
                print("  ballad - ceremonial / theatrical")
                print("  verse  - expressive")
                print("  coral  - warmer")
                print("Current voice: " .. tostring(OPENAI_TTS_VOICE))

            elseif lower:match("^voice%s+") then
                local requested = trim(input:match("^%S+%s+(.+)$") or "")
                if requested ~= "" then
                    OPENAI_TTS_VOICE = requested
                    print("OpenAI TTS voice set to: " .. OPENAI_TTS_VOICE)
                    local okSpeak, speakErr = speakToCity("Voice changed. JARVIS public broadcast voice is now set to " .. OPENAI_TTS_VOICE .. ".", true)
                    if not okSpeak then print("Voice test failed: " .. tostring(speakErr)) end
                else
                    print("Usage: voice cedar")
                end

            elseif lower == "tracks" then
                printTracks()

            elseif lower == "playmusic" then
                playRandomMusic()

            elseif lower == "stopmusic" then
                stopMusic("manual command")

            else
                addMessage("user", input)

                print("Thinking...")

                local reply, err = callOpenAI(chatHistory)

                if not reply then
                    print("ERROR: " .. s(err))
                    speakAsync("OpenAI request failed.")
                else
                    addMessage("assistant", reply)
                    print("")
                    print("JARVIS:")
                    print(reply)
                    print("")
                    stopMusic("JARVIS reply")
                    speakAsync(reply)
                end
            end
        end
    end
end

