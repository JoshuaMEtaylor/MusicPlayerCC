local function sendNodeCommand(baseMsg, timeout, discoverIfEmpty)
    openAllPaModems()

    local ids = {}
    for id in pairs(speakerNodes) do ids[#ids + 1] = id end
    table.sort(ids)

    if #ids == 0 and discoverIfEmpty ~= false then
        discoverSpeakerNodes(PA_NODE_DISCOVERY_TIMEOUT)

        ids = {}
        for id in pairs(speakerNodes) do ids[#ids + 1] = id end
        table.sort(ids)
    end

    if #ids == 0 then
        print("[NODE] No speaker nodes available.")
        return 0, 0
    end

    local commandId = nextPaCommandId(baseMsg.type or "node")
    local msg = {}

    for k, v in pairs(baseMsg) do msg[k] = v end

    msg.command_id = commandId
    msg.controller = os.getComputerID()

    for _, id in ipairs(ids) do
        rednet.send(id, msg, PA_NODE_PROTOCOL)
    end

    local okCount = 0
    local replies = 0
    local deadline = os.clock() + (timeout or PA_NODE_ACK_TIMEOUT)

    while os.clock() < deadline and replies < #ids do
        local remaining = deadline - os.clock()
        if remaining <= 0 then break end

        local sender, reply = rednet.receive(PA_NODE_PROTOCOL, remaining)

        if sender and type(reply) == "table" and reply.type == "ack" and reply.command_id == commandId then
            replies = replies + 1
            rememberNode(sender, reply)

            if reply.ok then okCount = okCount + 1 end

            print("[NODE] " .. tostring(reply.label or sender) .. ": " .. tostring(reply.status) .. " | speakers=" .. tostring(reply.speaker_count or "?"))
        end
    end

    if replies < #ids then
        print("[NODE] Warning: " .. tostring(#ids - replies) .. " node(s) did not ack " .. tostring(baseMsg.type) .. ".")
    end

    return okCount, #ids
end

