-- =============================================================================
-- SMALL UTILITIES
-- =============================================================================

local function s(v)
    if v == nil then return "nil" end
    return tostring(v)
end

local function hasArg(wanted)
    for _, arg in ipairs(args) do
        if tostring(arg) == wanted then
            return true
        end
    end
    return false
end

local function readAll(path)
    if not fs.exists(path) then return nil end
    local f = fs.open(path, "r")
    if not f then return nil end
    local text = f.readAll()
    f.close()
    return text
end

local function writeFile(path, text)
    local f = fs.open(path, "w")
    if not f then return false end
    f.write(text or "")
    f.close()
    return true
end

local function appendFile(path, text)
    local f = fs.open(path, "a")
    if not f then return false end
    f.write(text or "")
    f.close()
    return true
end

local function trim(str)
    str = tostring(str or "")
    str = str:gsub("^%s+", "")
    str = str:gsub("%s+$", "")
    return str
end

local function line()
    print(string.rep("-", 40))
end

local function limitText(text, maxChars)
    text = tostring(text or "")
    maxChars = tonumber(maxChars) or 1000
    if #text <= maxChars then return text end
    return text:sub(#text - maxChars + 1)
end

-- =============================================================================
-- SAFE SELF UPDATE
-- =============================================================================

local function selfUpdate()
    if hasArg("--updated") then
        return
    end

    if not http or not http.get then
        print("HTTP unavailable. Skipping update.")
        return
    end

    if not UPDATE_URL or UPDATE_URL == "" or UPDATE_URL:find("JarvisCC", 1, true) then
        print("Updater URL still looks like the default placeholder.")
        print("Set UPDATE_URL near the top of this file when your GitHub repo is ready.")
        print("Skipping update.")
        return
    end

    local program = shell and shell.getRunningProgram and shell.getRunningProgram() or "Jarvis"
    if not program or program == "" then program = "Jarvis" end

    print("[ JARVIS ]")
    print("Checking GitHub update...")

    local tmp = program .. ".new"
    local old = program .. ".old"

    fs.delete(tmp)

    local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
    local url = UPDATE_URL .. "?cb=" .. cb

    local handle = http.get(url, {
        ["User-Agent"] = "CC-Tweaked-JARVIS-Base-Updater",
        ["Cache-Control"] = "no-cache",
    })

    if not handle then
        print("Update check failed. Starting local copy.")
        sleep(0.5)
        return
    end

    local body = handle.readAll()
    handle.close()

    local okDownload =
        body and
        #body > 1000 and
        not body:find("404: Not Found", 1, true) and
        not body:find("<!DOCTYPE html", 1, true)

    if not okDownload then
        print("Update rejected: empty, invalid, or not raw Lua.")
        print("Starting local copy.")
        sleep(0.5)
        return
    end

    local f = fs.open(tmp, "w")
    if not f then
        print("Could not write update file. Starting local copy.")
        return
    end

    f.write(body)
    f.close()

    fs.delete(old)
    if fs.exists(program) then
        fs.move(program, old)
    end

    fs.move(tmp, program)

    print("Updated. Relaunching...")
    sleep(0.5)

    shell.run(program, "--updated")
    return "updated"
end

local updateResult = selfUpdate()
if updateResult == "updated" then
    return
end

-- =============================================================================
-- API KEY LOADING
-- =============================================================================

local function loadKey()
    -- Preferred style: JarvisKey.lua returns a string or table.
    local ok, result = pcall(function()
        return require("JarvisKey")
    end)

    if ok then
        if type(result) == "string" and trim(result) ~= "" then
            return trim(result)
        end

        if type(result) == "table" then
            local key =
                result.api_key or
                result.key or
                result.OPENAI_API_KEY or
                result.openai_api_key

            if type(key) == "string" and trim(key) ~= "" then
                return trim(key)
            end
        end
    end

    -- Fallback: read as plain text.
    if not fs.exists(KEY_FILE) then
        error("Missing " .. KEY_FILE .. ". Add your OpenAI API key file first.")
    end

    local text = trim(readAll(KEY_FILE) or "")

    local quoted = text:match('return%s+["\'](.-)["\']')
    if quoted and trim(quoted) ~= "" then
        return trim(quoted)
    end

    if text ~= "" and not text:find("return", 1, true) then
        return text
    end

    error("Could not load API key from " .. KEY_FILE)
end

local API_KEY = loadKey()

-- =============================================================================
-- OPENAI CALL
-- =============================================================================

local function extractText(data)
    if type(data) ~= "table" then return nil end

    if type(data.output_text) == "string" then
        return data.output_text
    end

    if type(data.output) == "table" then
        local parts = {}

        for _, item in ipairs(data.output) do
            if type(item) == "table" and type(item.content) == "table" then
                for _, content in ipairs(item.content) do
                    if type(content) == "table" then
                        if type(content.text) == "string" then
                            parts[#parts + 1] = content.text
                        elseif type(content.output_text) == "string" then
                            parts[#parts + 1] = content.output_text
                        end
                    end
                end
            end
        end

        if #parts > 0 then
            return table.concat(parts, "\n")
        end
    end

    return nil
end

local function callOpenAI(messages, overrideSystemPrompt)
    if not http or not http.post then
        return nil, "HTTP API unavailable."
    end

    local input = {}

    input[#input + 1] = {
        role = "system",
        content = overrideSystemPrompt or SYSTEM_PROMPT
    }

    for _, msg in ipairs(messages) do
        input[#input + 1] = msg
    end

    local body = textutils.serializeJSON({
        model = MODEL,
        input = input
    })

    local response = http.post(
        "https://api.openai.com/v1/responses",
        body,
        {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. API_KEY
        }
    )

    if not response then
        return nil, "No response from OpenAI."
    end

    local raw = response.readAll()
    response.close()

    writeFile(RAW_RESPONSE_FILE, raw)

    local data = textutils.unserializeJSON(raw)
    if not data then
        return nil, "Could not parse OpenAI JSON. Raw response saved to " .. RAW_RESPONSE_FILE
    end

    if data.error then
        local msg = "Unknown OpenAI error."
        if type(data.error) == "table" and data.error.message then
            msg = data.error.message
        end
        return nil, "OpenAI error: " .. s(msg)
    end

    local text = extractText(data)
    if not text or text == "" then
        return nil, "Could not extract response text. Raw response saved to " .. RAW_RESPONSE_FILE
    end

    return text, nil
end

-- =============================================================================
-- MINECRAFT TIME ENGINE
-- Matched to the standalone MinecraftTimeTerminal style:
-- - Day 0 begins 00/00/0000
-- - Gregorian month lengths
-- - Minecraft ingame day/time from os.day("ingame") and os.time("ingame")
-- =============================================================================

local MONTH_NAMES = {
    "January", "February", "March", "April", "May", "June",
    "July", "August", "September", "October", "November", "December"
}

local MINECRAFT_DAY_MS = 20 * 60 * 1000

local function nowMs()
    if os.epoch then return os.epoch("utc") end
    return math.floor(os.time() * 1000)
end

local function isLeapYear(year)
    year = math.floor(tonumber(year) or 0)
    if year % 400 == 0 then return true end
    if year % 100 == 0 then return false end
    return year % 4 == 0
end

local function monthLength(month_zero, year)
    local base = {31,28,31,30,31,30,31,31,30,31,30,31}
    local idx = (math.floor(tonumber(month_zero) or 0) % 12) + 1
    if idx == 2 and isLeapYear(year) then return 29 end
    return base[idx]
end

local function currentMinecraftDay()
    if os.day then
        local ok, day = pcall(os.day, "ingame")
        if ok and tonumber(day) then return math.floor(tonumber(day)) end
        ok, day = pcall(os.day)
        if ok and tonumber(day) then return math.floor(tonumber(day)) end
    end
    return math.floor(nowMs() / MINECRAFT_DAY_MS)
end

local function currentMinecraftTimeHours()
    if os.time then
        local ok, t = pcall(os.time, "ingame")
        if ok and tonumber(t) then return tonumber(t) end
        ok, t = pcall(os.time)
        if ok and tonumber(t) then return tonumber(t) end
    end
    local dayMs = nowMs() % MINECRAFT_DAY_MS
    return (dayMs / MINECRAFT_DAY_MS) * 24
end

local function calendarFromMinecraftDay(day)
    day = math.floor(tonumber(day) or 0)
    if day < 0 then day = 0 end

    local year = 0
    local remaining = day

    while true do
        local year_len = isLeapYear(year) and 366 or 365
        if remaining < year_len then break end
        remaining = remaining - year_len
        year = year + 1
    end

    local dayOfYear = remaining
    local month = 0

    while true do
        local len = monthLength(month, year)
        if remaining < len then break end
        remaining = remaining - len
        month = month + 1
    end

    return {
        absolute_day = day,
        year = year,
        month = month,
        month_name = MONTH_NAMES[(month % 12) + 1],
        day_of_month = remaining,
        day_of_year = dayOfYear,
        leap_year = isLeapYear(year),
    }
end

local function minecraftClock()
    local absolute_day = currentMinecraftDay()
    local cal = calendarFromMinecraftDay(absolute_day)

    local t = currentMinecraftTimeHours() % 24
    local tick = math.floor(((t / 24) * 24000) + 0.5) % 24000
    local total_seconds = math.floor((tick / 24000) * 86400)
    local hour = math.floor(total_seconds / 3600) % 24
    local minute = math.floor((total_seconds % 3600) / 60)
    local second = total_seconds % 60

    local date_text = string.format("%02d/%02d/%04d", cal.day_of_month, cal.month, cal.year)
    local time_text = string.format("%02d:%02d:%02d", hour, minute, second)

    return {
        day = absolute_day,
        absolute_day = absolute_day,
        year = cal.year,
        month = cal.month,
        month_name = cal.month_name,
        day_of_month = cal.day_of_month,
        day_of_year = cal.day_of_year,
        leap_year = cal.leap_year,
        tick = tick,
        hour = hour,
        minute = minute,
        second = second,
        date_text = date_text,
        time_text = time_text,
        full_text = date_text .. " " .. time_text,
    }
end

-- =============================================================================
-- GPT MORNING STATE BROADCAST
-- =============================================================================

local function lastMorningDay()
    local text = trim(readAll(MORNING_STATE_FILE) or "")
    return tonumber(text)
end

local function saveMorningDay(day)
    writeFile(MORNING_STATE_FILE, tostring(day))
end

local function readMorningHistory()
    return limitText(readAll(MORNING_HISTORY_FILE) or "", MORNING_HISTORY_MAX_CHARS)
end

local function appendMorningHistory(day, text)
    local entry = "\n\n--- DAY " .. tostring(day) .. " ---\n" .. tostring(text or "")
    local existing = readAll(MORNING_HISTORY_FILE) or ""
    local combined = limitText(existing .. entry, MORNING_HISTORY_MAX_CHARS)
    writeFile(MORNING_HISTORY_FILE, combined)
end

local function musicAttentionText()
    if fs.exists(MUSIC_PLAYER_PROGRAM) then
        return "Daily music player detected. Run `" .. MUSIC_PLAYER_PROGRAM .. "` when ready."
    end

    return "Daily music player not found on this computer yet. Expected program: `" .. MUSIC_PLAYER_PROGRAM .. "`."
end

local function tryOpenMusicTab()
    if not AUTO_OPEN_MUSIC_TAB then return false end
    if not fs.exists(MUSIC_PLAYER_PROGRAM) then return false end

    if multishell and multishell.launch then
        local id = multishell.launch({}, MUSIC_PLAYER_PROGRAM)
        if id then
            multishell.setTitle(id, "Daily Music")
            return true
        end
    end

    return false
end

local function fallbackMorningBroadcast(clock)
    return table.concat({
        "Good morning, citizens of the Ako Dynasty.",
        "",
        "Under the red and black banners of Ako, the new day rises with order, strength, and purpose. Let every workshop, field, ledger, and machine remember its place in the greater harmony of the Dynasty.",
        "",
        "The State calls for disciplined labour, clean accounts, and loyal hearts. Begin now with the approved daily patriotic music programme, and let its rhythm carry the will of Ako through every street.",
        "",
        "Remain productive. Remain orderly. The Dynasty advances."
    }, "\n")
end

local function generateMorningBroadcast(clock, forced)
    local history = readMorningHistory()

    local morningSystem = [[
You are JARVIS State Radio, the fictional official morning broadcaster of a Minecraft nation.

Generate one fresh morning patriotic radio address.

Identity:
- Nation: the Ako Dynasty.
- Leader: Ako.
- Colours: red and black.
- Theme: East Asian dynastic/state-radio aesthetic.

Style:
- Grand, ceremonial, confident, state-news-presenter tone.
- Similar energy to an extremely loyal official broadcaster, but completely fictional.
- Avoid real-world country names, real-world political parties, real-world ethnic claims, and real-world leaders.
- Do not mention China, North Korea, communism, fascism, or any real regime.
- Make it sound like a dramatic in-universe morning news/radio opening.
- It should be unique and not reuse previous wording.
- It should direct citizens toward the daily patriotic/propaganda music programme near the end.
- Keep it between 90 and 150 words.
- Return only the broadcast text. No markdown. No JSON.
]]

    local userPrompt = table.concat({
        "Create today's morning address.",
        "",
        "Minecraft date: " .. tostring(clock.date_text),
        "Minecraft time: " .. tostring(clock.time_text),
        "Absolute Minecraft day: " .. tostring(clock.absolute_day),
        "Forced test: " .. tostring(forced == true),
        "",
        "Avoid repeating these previous broadcasts:",
        history ~= "" and history or "No previous broadcasts recorded.",
    }, "\n")

    local reply, err = callOpenAI({
        {
            role = "user",
            content = userPrompt
        }
    }, morningSystem)

    if not reply then
        return fallbackMorningBroadcast(clock), "GPT morning generation failed: " .. tostring(err)
    end

    reply = trim(reply)

    if reply == "" then
        return fallbackMorningBroadcast(clock), "GPT morning generation returned empty text."
    end

    return reply, nil
end

local function printMorningBroadcast(forced)
    local c = minecraftClock()

    print("")
    line()
    print("JARVIS MORNING STATE BROADCAST")
    print("Nation: " .. NATION_NAME)
    print("Leader: " .. LEADER_NAME)
    print("Colours: " .. STATE_COLOURS)
    print("Date: " .. c.date_text .. "  Time: " .. c.time_text)
    print("")

    print("Composing fresh broadcast...")
    local speech, err = generateMorningBroadcast(c, forced)

    print("")
    print(speech)
    print("")

    if err then
        print("NOTICE: " .. err)
        print("")
    end

    print(musicAttentionText())

    if tryOpenMusicTab() then
        print("Daily music programme opened in a new tab.")
    else
        print("Music command: " .. MUSIC_PLAYER_PROGRAM)
    end

    if not forced then
        appendMorningHistory(c.absolute_day, speech)
    else
        print("")
        print("(Forced test broadcast. Daily trigger state/history was not changed.)")
    end

    line()
    print("")
end

local function shouldRunMorningBroadcast()
    if not MORNING_ENABLED then return false end

    local c = minecraftClock()
    local last = lastMorningDay()

    if last == c.absolute_day then
        return false
    end

    if c.hour >= MORNING_START_HOUR and c.hour < MORNING_END_HOUR then
        return true, c
    end

    return false
end

local function morningBroadcastLoop()
    while true do
        local ok, c = shouldRunMorningBroadcast()

        if ok and c then
            printMorningBroadcast(false)
            saveMorningDay(c.absolute_day)
        end

        sleep(MORNING_CHECK_SECONDS)
    end
end

-- =============================================================================
-- CHAT LOOP
-- =============================================================================

local chatHistory = {}

local function addMessage(role, content)
    chatHistory[#chatHistory + 1] = {
        role = role,
        content = content
    }

    -- Keep the base client light.
    while #chatHistory > 12 do
        table.remove(chatHistory, 1)
    end
end

local function bootScreen()
    term.clear()
    term.setCursorPos(1, 1)

    print("JARVIS BASE CORE")
    print("Version: " .. VERSION)
    print("Model: " .. MODEL)
    print("")
    print("Mode: clean chat + GPT morning state broadcast")
    print("Nation: " .. NATION_NAME)
    print("Leader: " .. LEADER_NAME)
    print("Colours: " .. STATE_COLOURS)
    print("Theme: " .. CULTURAL_THEME)
    print("")
    print("No turtles. No squads. No TTS. No monitors. No databanks.")
    print("")
    print("Commands:")
    print("  exit      - close JARVIS")
    print("  clear     - clear chat history")
    print("  raw       - show latest raw response file")
    print("  time      - show Minecraft date/time")
    print("  morning   - force fresh GPT morning address")
    print("  music     - show daily music prompt")
    print("")
    line()
end

local function chatLoop()
    bootScreen()

    while true do
        write("> ")
        local input = read()

        if input then
            input = trim(input)
            local lower = input:lower()

            if input == "" then
                -- ignore empty input

            elseif lower == "exit" then
                print("JARVIS offline.")
                return

            elseif lower == "clear" then
                chatHistory = {}
                print("Chat history cleared.")

            elseif lower == "raw" then
                print("Latest raw response file: " .. RAW_RESPONSE_FILE)

            elseif lower == "time" then
                local c = minecraftClock()
                print("Minecraft date/time: " .. c.full_text .. " | Abs day " .. tostring(c.absolute_day))

            elseif lower == "morning" then
                printMorningBroadcast(true)

            elseif lower == "music" then
                print(musicAttentionText())
                print("Music command: " .. MUSIC_PLAYER_PROGRAM)

            else
                addMessage("user", input)

                print("Thinking...")

                local reply, err = callOpenAI(chatHistory)

                if not reply then
                    print("ERROR: " .. s(err))
                else
                    addMessage("assistant", reply)
                    print("")
                    print("JARVIS:")
                    print(reply)
                    print("")
                end
            end
        end
    end
end

