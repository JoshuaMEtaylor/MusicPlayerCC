local function peripheralIsSpeaker(name)
    if not name then return false end

    if peripheral.hasType then
        local ok, result = pcall(function()
            return peripheral.hasType(name, "speaker")
        end)
        if ok and result == true then return true end
    end

    local pType = peripheral.getType(name)

    if pType == "speaker" then return true end

    if type(pType) == "table" then
        for _, t in ipairs(pType) do
            if t == "speaker" then return true end
        end
    end

    return false
end

local function scanSpeakers()
    citySpeakers = {}

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralIsSpeaker(name) then
            local wrapped = peripheral.wrap(name)

            if wrapped and wrapped.playAudio then
                citySpeakers[#citySpeakers + 1] = {
                    name = name,
                    speaker = wrapped,
                    type = peripheral.getType(name),
                }
            end
        end
    end

    table.sort(citySpeakers, function(a, b)
        local an = tonumber(tostring(a.name):match("(%d+)$"))
        local bn = tonumber(tostring(b.name):match("(%d+)$"))

        if an and bn and an ~= bn then
            return an < bn
        end

        return tostring(a.name) < tostring(b.name)
    end)

    return #citySpeakers
end

