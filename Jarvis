-- =============================================================================
-- SMALL UTILITIES
-- =============================================================================

local function s(v)
    if v == nil then return "nil" end
    return tostring(v)
end

local function trim(str)
    str = tostring(str or "")
    str = str:gsub("^%s+", "")
    str = str:gsub("%s+$", "")
    return str
end

local function hasArg(wanted)
    for _, arg in ipairs(args) do
        if tostring(arg) == wanted then return true end
    end
    return false
end

local function readAll(path)
    if not fs.exists(path) then return nil end
    local f = fs.open(path, "r")
    if not f then return nil end
    local text = f.readAll()
    f.close()
    return text
end

local function writeFile(path, text)
    local f = fs.open(path, "w")
    if not f then return false end
    f.write(text or "")
    f.close()
    return true
end

local function line()
    print(string.rep("-", 40))
end

local function limitText(text, maxChars)
    text = tostring(text or "")
    maxChars = tonumber(maxChars) or 1000
    if #text <= maxChars then return text end
    return text:sub(#text - maxChars + 1)
end

local function boolText(v)
    return v and "yes" or "no"
end

local function encodePath(path)
    return tostring(path):gsub("([^%w%-%._~/])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
end

local function niceTrackName(fileName)
    local name = tostring(fileName or "")
    name = name:gsub("%.dfpwm$", ""):gsub("%.DFPWM$", "")
    name = name:gsub("%%20", " ")
    name = name:gsub("%s+", " ")
    return name
end

-- =============================================================================
-- SAFE SELF UPDATE
-- =============================================================================

local function selfUpdate(force)
    if not UPDATE_ENABLED then return end

    if hasArg(UPDATE_SKIP_ARG) and not force then
        print("Auto-update skipped for freshly relaunched copy.")
        return
    end

    if not http or not http.get then
        print("HTTP unavailable. Skipping update.")
        return
    end

    if not shell or not shell.run then
        print("Shell API unavailable. Skipping update.")
        return
    end

    if not UPDATE_URL or UPDATE_URL == "" then
        print("No UPDATE_URL set. Skipping update.")
        return
    end

    local program = shell.getRunningProgram and shell.getRunningProgram() or "Jarvis"
    if not program or program == "" then program = "Jarvis" end

    print("[ JARVIS Town Broadcast Core ]")
    print("Checking GitHub update...")

    local tmp = program .. ".new"
    local old = program .. ".old"
    fs.delete(tmp)

    local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
    local sep = UPDATE_URL:find("?", 1, true) and "&" or "?"
    local url = UPDATE_URL .. sep .. "cb=" .. cb

    local handle = http.get(url, {
        ["User-Agent"] = "CC-Tweaked-JARVIS-Town-Broadcast-Updater",
        ["Cache-Control"] = "no-cache",
    })

    if not handle then
        print("Update failed: no HTTP response. Keeping local copy.")
        sleep(0.5)
        return
    end

    local body = handle.readAll()
    handle.close()

    local okDownload =
        body and
        #body > 1000 and
        not body:find("404: Not Found", 1, true) and
        not body:find("<!DOCTYPE html", 1, true) and
        not body:find("<html", 1, true)

    if not okDownload then
        fs.delete(tmp)
        print("Update rejected: empty, invalid, or not raw Lua. Keeping local copy.")
        sleep(0.5)
        return
    end

    local f = fs.open(tmp, "w")
    if not f then
        print("Could not write temporary update file. Keeping local copy.")
        return
    end

    f.write(body)
    f.close()

    fs.delete(old)
    if fs.exists(program) then fs.move(program, old) end
    fs.move(tmp, program)

    print("Updated. Relaunching...")
    sleep(0.5)

    local relaunch = { program, UPDATE_SKIP_ARG }
    for i = 1, #args do
        if tostring(args[i]) ~= UPDATE_SKIP_ARG then
            relaunch[#relaunch + 1] = tostring(args[i])
        end
    end

    local unpackFn = table.unpack or unpack
    shell.run(unpackFn(relaunch))
    return "updated"
end

local updateResult = selfUpdate(false)
if updateResult == "updated" then return end

-- =============================================================================
-- API KEY LOADING
-- =============================================================================

local function loadKey()
    local ok, result = pcall(function()
        return require("JarvisKey")
    end)

    if ok then
        if type(result) == "string" and trim(result) ~= "" then
            return trim(result)
        end

        if type(result) == "table" then
            local key = result.api_key or result.key or result.OPENAI_API_KEY or result.openai_api_key
            if type(key) == "string" and trim(key) ~= "" then
                return trim(key)
            end
        end
    end

    if not fs.exists(KEY_FILE) then
        error("Missing " .. KEY_FILE .. ". Add your OpenAI API key file first.")
    end

    local text = trim(readAll(KEY_FILE) or "")
    local quoted = text:match('return%s+["\'](.-)["\']')
    if quoted and trim(quoted) ~= "" then return trim(quoted) end
    if text ~= "" and not text:find("return", 1, true) then return text end

    error("Could not load API key from " .. KEY_FILE)
end

local API_KEY = loadKey()

-- =============================================================================
-- OPENAI CALL
-- =============================================================================

local function extractText(data)
    if type(data) ~= "table" then return nil end

    if type(data.output_text) == "string" then
        return data.output_text
    end

    if type(data.output) == "table" then
        local parts = {}

        for _, item in ipairs(data.output) do
            if type(item) == "table" and type(item.content) == "table" then
                for _, content in ipairs(item.content) do
                    if type(content) == "table" then
                        if type(content.text) == "string" then
                            parts[#parts + 1] = content.text
                        elseif type(content.output_text) == "string" then
                            parts[#parts + 1] = content.output_text
                        end
                    end
                end
            end
        end

        if #parts > 0 then return table.concat(parts, "\n") end
    end

    return nil
end

local function callOpenAI(messages, overrideSystemPrompt)
    if not http or not http.post then
        return nil, "HTTP API unavailable."
    end

    local input = {
        {
            role = "system",
            content = overrideSystemPrompt or SYSTEM_PROMPT
        }
    }

    for _, msg in ipairs(messages) do
        input[#input + 1] = msg
    end

    local body = textutils.serializeJSON({
        model = MODEL,
        input = input
    })

    local response = http.post(
        "https://api.openai.com/v1/responses",
        body,
        {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. API_KEY
        }
    )

    if not response then return nil, "No response from OpenAI." end

    local raw = response.readAll()
    response.close()

    writeFile(RAW_RESPONSE_FILE, raw)

    local data = textutils.unserializeJSON(raw)
    if not data then
        return nil, "Could not parse OpenAI JSON. Raw response saved to " .. RAW_RESPONSE_FILE
    end

    if data.error then
        local msg = "Unknown OpenAI error."
        if type(data.error) == "table" and data.error.message then msg = data.error.message end
        return nil, "OpenAI error: " .. s(msg)
    end

    local text = extractText(data)
    if not text or text == "" then
        return nil, "Could not extract response text. Raw response saved to " .. RAW_RESPONSE_FILE
    end

    return text, nil
end


