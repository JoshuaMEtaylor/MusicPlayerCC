local function waitSpeakerEvent(shouldContinue)
    local timer = os.startTimer(AUDIO_WAIT_TIMEOUT)

    while true do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        local event, p1 = os.pullEvent()

        if event == "speaker_audio_empty" then
            return true
        elseif event == "timer" and p1 == timer then
            return true
        end
    end
end

local function playAudioBufferOnAll(buffer, volume, debug, shouldContinue)
    if #citySpeakers == 0 then scanSpeakers() end

    if #citySpeakers == 0 then
        return false, "No visible speaker peripherals."
    end

    local pending = {}
    for i = 1, #citySpeakers do pending[i] = true end

    local attempts = 0

    while true do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        attempts = attempts + 1
        local remaining = 0
        local hadError = false

        for i, item in ipairs(citySpeakers) do
            if pending[i] then
                local ok, accepted = pcall(function()
                    return item.speaker.playAudio(buffer, volume or 1)
                end)

                if ok and accepted then
                    pending[i] = false
                else
                    remaining = remaining + 1
                    if not ok then
                        hadError = true
                        if debug then
                            print("playAudio error on " .. tostring(item.name) .. ": " .. tostring(accepted))
                        end
                    end
                end
            end
        end

        if remaining == 0 then
            return true
        end

        if hadError and attempts > 3 then
            return false, "One or more speakers rejected audio buffers."
        end

        local waited, waitErr = waitSpeakerEvent(shouldContinue)
        if not waited then
            return false, waitErr
        end
    end
end

local function playOnAllSpeakers(sound, volume, pitch)
    if #citySpeakers == 0 then scanSpeakers() end

    if #citySpeakers == 0 then
        print("No visible speaker peripherals.")
        return false, 0
    end

    local okCount = 0

    for _, item in ipairs(citySpeakers) do
        local ok, err = pcall(function()
            item.speaker.playSound(sound, volume or 1, pitch or 1)
        end)

        if ok then
            okCount = okCount + 1
        else
            print("Sound failed on " .. tostring(item.name) .. ": " .. tostring(err))
        end
    end

    return okCount > 0, okCount
end

local function stopAllSpeakers()
    if #citySpeakers == 0 then scanSpeakers() end

    local count = 0

    for _, item in ipairs(citySpeakers) do
        local ok = pcall(function()
