local disabledSpeakers = {}

local function loadDisabledSpeakers()
    disabledSpeakers = {}

    local raw = readAll(DISABLED_SPEAKERS_FILE)
    if not raw then return end

    for lineText in raw:gmatch("[^\r\n]+") do
        local name = trim(lineText)
        if name ~= "" then
            disabledSpeakers[name] = true
        end
    end
end

local function saveDisabledSpeakers()
    local names = {}

    for name, disabled in pairs(disabledSpeakers) do
        if disabled then names[#names + 1] = name end
    end

    table.sort(names)
    writeFile(DISABLED_SPEAKERS_FILE, table.concat(names, "\n"))
end

local function isSpeakerDisabled(name)
    return disabledSpeakers[tostring(name or "")] == true
end

local function setSpeakerDisabled(name, disabled)
    name = tostring(name or "")

    if name == "" then
        return false, "No speaker name supplied."
    end

    if disabled then
        disabledSpeakers[name] = true
    else
        disabledSpeakers[name] = nil
    end

    saveDisabledSpeakers()
    return true
end

