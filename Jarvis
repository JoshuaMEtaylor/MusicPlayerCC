local function waitSpeakerEventForPending(pendingByName, shouldContinue)
    local timer = os.startTimer(AUDIO_WAIT_TIMEOUT)

    while true do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        local event, p1 = os.pullEvent()

        if event == "speaker_audio_empty" then
            -- CC:Tweaked sends the speaker peripheral name as p1.
            -- If a name is supplied, only use it when one of our pending speakers is ready.
            -- If a mod/version omits the name, wake anyway and retry all pending speakers.
            if p1 == nil or pendingByName[tostring(p1)] then
                return true
            end
        elseif event == "peripheral" or event == "peripheral_detach" then
            -- Wires/modems may change while running. Rescan and let caller retry.
            return true
        elseif event == "timer" and p1 == timer then
            -- Timeout retry. This avoids getting stuck if an empty event is missed.
            return true
        end
    end
end

local function playAudioBufferOnAll(buffer, volume, debug, shouldContinue)
    -- Always rescan for fanout. Remote speaker networks can change while the city is running.
    scanSpeakers()

    local speakersToUse = activeSpeakers()

    if #speakersToUse == 0 then
        return false, "No active speaker peripherals."
    end

    local pending = {}
    local pendingByName = {}
    local pendingCount = 0

    for _, item in ipairs(speakersToUse) do
        pending[#pending + 1] = item
        pendingByName[tostring(item.name)] = true
        pendingCount = pendingCount + 1
    end

    local attempts = 0
    local maxAttempts = 200

    while pendingCount > 0 do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        attempts = attempts + 1

        if attempts > maxAttempts then
            local missing = {}
            for _, item in ipairs(pending) do
                if pendingByName[tostring(item.name)] then
                    missing[#missing + 1] = tostring(item.name)
                end
            end

            return false, "Timed out sending audio buffer to: " .. table.concat(missing, ", ")
        end

        for _, item in ipairs(pending) do
            local name = tostring(item.name)

            if pendingByName[name] then
                local ok, accepted = pcall(function()
                    return item.speaker.playAudio(buffer, volume or 1)
                end)

                if ok and accepted then
                    pendingByName[name] = nil
                    pendingCount = pendingCount - 1

                    if debug then
                        print("[AUDIO] accepted: " .. name)
                    end
                elseif not ok then
                    if debug then
                        print("[AUDIO] playAudio error on " .. name .. ": " .. tostring(accepted))
                    end

                    -- The peripheral may have rewrapped badly. Rescan next retry.
                    scanSpeakers()
                end
            end
        end

        if pendingCount > 0 then
            local waited, waitErr = waitSpeakerEventForPending(pendingByName, shouldContinue)
            if not waited then
                return false, waitErr
            end
        end

        sleep(0)
    end

    return true
end


local function waitForTargetSpeakersEmpty(label, timeoutSeconds, debug, shouldContinue)
    scanSpeakers()

    local speakersToUse = activeSpeakers()

    if #speakersToUse == 0 then
        return false, "No targeted speakers."
    end

    local pending = {}
    local pendingCount = 0

    for _, item in ipairs(speakersToUse) do
        local name = tostring(item.name)
        pending[name] = true
        pendingCount = pendingCount + 1
    end

    local timer = os.startTimer(timeoutSeconds or AUDIO_DRAIN_TIMEOUT)

    if debug then
        print("[AUDIO] Waiting for final buffer drain: " .. tostring(label or "audio") .. " on " .. tostring(pendingCount) .. " speaker(s).")
    end

    while pendingCount > 0 do
        if shouldContinue and not shouldContinue() then
            return false, "cancelled"
        end

        local event, p1 = os.pullEvent()

        if event == "speaker_audio_empty" then
            if p1 == nil then
                -- Older/weird versions may not provide the name. Treat as enough signal to continue.
                if debug then print("[AUDIO] unnamed speaker_audio_empty event received.") end
                return true
            end

            local name = tostring(p1)

            if pending[name] then
                pending[name] = nil
                pendingCount = pendingCount - 1

                if debug then
                    print("[AUDIO] drained: " .. name .. " (" .. tostring(pendingCount) .. " left)")
                end
            end
        elseif event == "peripheral" or event == "peripheral_detach" then
            -- If the network changes mid-broadcast, do not deadlock waiting for old names.
            if debug then print("[AUDIO] peripheral network changed while draining.") end
            return false, "speaker network changed"
        elseif event == "timer" and p1 == timer then
            local missing = {}

            for name, stillPending in pairs(pending) do
                if stillPending then missing[#missing + 1] = name end
            end

            table.sort(missing)

            return false, "Drain timeout waiting for: " .. table.concat(missing, ", ")
        end
    end

    return true
end

local function hardStopAllSpeakers(reason, verbose)
