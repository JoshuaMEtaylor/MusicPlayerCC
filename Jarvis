    -- Give clients/server a small moment to process stop packets before new audio begins.
    sleep(PRE_MUSIC_SETTLE_SECONDS)

    return count
end


local function makeSilentProbeBuffer()
    local buffer = {}

    -- Short silent PCM probe. It should not be audible, but it still goes
    -- through speaker.playAudio and should produce speaker_audio_empty.
    for i = 1, 4096 do
        buffer[i] = 0
    end

    return buffer
end

local function speakerPingAll(label, debug)
    scanSpeakers()

    local targetCount = activeSpeakerCount()

    if targetCount == 0 then
        return false, "No targeted speakers."
    end

    if debug then
        print("[PING] Speaker ping: " .. tostring(label or "audio") .. " | targets=" .. tostring(targetCount) .. "/" .. tostring(speakerCount()))
    end

    local probe = makeSilentProbeBuffer()

    for attempt = 1, SPEAKER_PING_ATTEMPTS do
        if debug then
            print("[PING] Attempt " .. tostring(attempt) .. "/" .. tostring(SPEAKER_PING_ATTEMPTS))
        end

        hardStopAllSpeakers("speaker ping", debug)
        sleep(0.2)

        local sent, sendErr = playAudioBufferOnAll(probe, 1, debug, nil)

        if sent then
            local drained, drainErr = waitForTargetSpeakersEmpty("speaker ping " .. tostring(label or ""), SPEAKER_PING_TIMEOUT, debug, nil)

            if drained then
                if debug then print("[PING] All targeted speakers responded.") end
                return true
            end

            if debug then print("[PING] Drain failed: " .. tostring(drainErr)) end
        else
            if debug then print("[PING] Send failed: " .. tostring(sendErr)) end
        end
    end

    hardStopAllSpeakers("failed speaker ping", debug)
    return false, "One or more speakers did not respond to ping."
end

local function preflightSpeakers(label, debug)
    local ok, err = speakerPingAll(label, debug)

    if not ok then
        print("[PING] WARNING: " .. tostring(err))
        print("[PING] JARVIS will still attempt playback to every visible speaker.")
        return false, err
    end

    return true
end

local function lockstepDrainAfterChunk(label, debug, shouldContinue)
    if not AUDIO_LOCKSTEP_MODE then
        return true
    end

    local drained, drainErr = waitForTargetSpeakersEmpty(label or "audio chunk", AUDIO_LOCKSTEP_TIMEOUT, debug, shouldContinue)

    if not drained then
        if drainErr == "cancelled" then
            return false, drainErr
        end

        if debug then
            print("[SYNC] Lockstep drain warning: " .. tostring(drainErr))
        end

        -- Keep all speakers together. If one misses its ready event, reset all
        -- buffers so it cannot lag behind with old audio.
        hardStopAllSpeakers("lockstep recovery", debug)
    end

    return true
end


local function playOnAllSpeakers(sound, volume, pitch)
