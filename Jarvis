local function encodePath(path)
    return tostring(path or ""):gsub("([^%w%-%._~/])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
end

local function niceTrackName(fileName)
    local name = tostring(fileName or "")
    name = name:gsub("%.dfpwm$", "")
    name = name:gsub("%.DFPWM$", "")
    name = name:gsub("%%20", " ")
    name = name:gsub("%s+", " ")
    return name
end

local function musicUrlRawGithub(fileName)
    return MUSIC_RAW_BASE_RAWGITHUB .. encodePath(fileName)
end

local function musicUrlGithubRaw(fileName)
