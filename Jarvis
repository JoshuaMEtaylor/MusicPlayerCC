-- =============================================================================
-- MINECRAFT TIME ENGINE
-- =============================================================================

local MONTH_NAMES = {
    "January", "February", "March", "April", "May", "June",
    "July", "August", "September", "October", "November", "December"
}

local MINECRAFT_DAY_MS = 20 * 60 * 1000

local function nowMs()
    if os.epoch then return os.epoch("utc") end
    return math.floor(os.time() * 1000)
end

local function isLeapYear(year)
    year = math.floor(tonumber(year) or 0)
    if year % 400 == 0 then return true end
    if year % 100 == 0 then return false end
    return year % 4 == 0
end

local function monthLength(month_zero, year)
    local base = {31,28,31,30,31,30,31,31,30,31,30,31}
    local idx = (math.floor(tonumber(month_zero) or 0) % 12) + 1
    if idx == 2 and isLeapYear(year) then return 29 end
    return base[idx]
end

local function currentMinecraftDay()
    if os.day then
        local ok, day = pcall(os.day, "ingame")
        if ok and tonumber(day) then return math.floor(tonumber(day)) end
        ok, day = pcall(os.day)
        if ok and tonumber(day) then return math.floor(tonumber(day)) end
    end
    return math.floor(nowMs() / MINECRAFT_DAY_MS)
end

local function currentMinecraftTimeHours()
    if os.time then
        local ok, t = pcall(os.time, "ingame")
        if ok and tonumber(t) then return tonumber(t) end
        ok, t = pcall(os.time)
        if ok and tonumber(t) then return tonumber(t) end
    end
    local dayMs = nowMs() % MINECRAFT_DAY_MS
    return (dayMs / MINECRAFT_DAY_MS) * 24
end

local function calendarFromMinecraftDay(day)
    day = math.floor(tonumber(day) or 0)
    if day < 0 then day = 0 end

    local year = 0
    local remaining = day

    while true do
        local year_len = isLeapYear(year) and 366 or 365
        if remaining < year_len then break end
        remaining = remaining - year_len
        year = year + 1
    end

    local dayOfYear = remaining
    local month = 0

    while true do
        local len = monthLength(month, year)
        if remaining < len then break end
        remaining = remaining - len
        month = month + 1
    end

    return {
        absolute_day = day,
        year = year,
        month = month,
        month_name = MONTH_NAMES[(month % 12) + 1],
        day_of_month = remaining,
        day_of_year = dayOfYear,
        leap_year = isLeapYear(year),
    }
end

local function minecraftClock()
    local absolute_day = currentMinecraftDay()
    local cal = calendarFromMinecraftDay(absolute_day)

    local t = currentMinecraftTimeHours() % 24
    local tick = math.floor(((t / 24) * 24000) + 0.5) % 24000
    local total_seconds = math.floor((tick / 24000) * 86400)
    local hour = math.floor(total_seconds / 3600) % 24
    local minute = math.floor((total_seconds % 3600) / 60)
    local second = total_seconds % 60

    local date_text = string.format("%02d/%02d/%04d", cal.day_of_month, cal.month, cal.year)
    local time_text = string.format("%02d:%02d:%02d", hour, minute, second)

    return {
        day = absolute_day,
        absolute_day = absolute_day,
        year = cal.year,
        month = cal.month,
        month_name = cal.month_name,
        day_of_month = cal.day_of_month,
        day_of_year = cal.day_of_year,
        leap_year = cal.leap_year,
        tick = tick,
        hour = hour,
        minute = minute,
        second = second,
        date_text = date_text,
        time_text = time_text,
        full_text = date_text .. " " .. time_text,
    }
end

