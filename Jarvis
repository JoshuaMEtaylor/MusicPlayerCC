local musicTracks = {}

local function makeTrackUrl(fileName)
    return MUSIC_RAW_BASE .. encodePath(fileName)
end

local function loadTracksFromGitHub()
    if not http or not http.get then
        return false, "HTTP unavailable."
    end

    print("[MUSIC] Loading track list from GitHub...")

    local handle = http.get(MUSIC_API_URL, {
        ["User-Agent"] = "CC-Tweaked-JARVIS-Music",
        ["Accept"] = "application/vnd.github+json",
    })

    if not handle then
        return false, "Could not contact GitHub contents API."
    end

    local code = "?"
    if handle.getResponseCode then
        local okCode, c = pcall(function() return handle.getResponseCode() end)
        if okCode then code = tostring(c) end
    end

    local body = handle.readAll()
    handle.close()

    print("[MUSIC] GitHub API HTTP " .. tostring(code))

    local data = textutils.unserializeJSON(body)
    if type(data) ~= "table" then
        return false, "Could not parse GitHub track list JSON."
    end

    local found = {}

    for _, item in ipairs(data) do
        if type(item) == "table" and item.type == "file" and type(item.name) == "string" then
            if item.name:lower():match("%.dfpwm$") then
                found[#found + 1] = {
                    file = item.name,
                    name = niceTrackName(item.name),
                    size = tonumber(item.size) or 0,
                    url = makeTrackUrl(item.name),
                }
            end
        end
    end

    table.sort(found, function(a, b)
        return tostring(a.name):lower() < tostring(b.name):lower()
    end)

    musicTracks = found

    if #musicTracks == 0 then
        return false, "No .dfpwm tracks found in repo root."
    end

    return true, #musicTracks
end

local function ensureTracks()
    if #musicTracks > 0 then return true, #musicTracks end
    return loadTracksFromGitHub()
end

local function printTracks()
    local ok, result = ensureTracks()

    print("")
    line()
    print("APPROVED MUSIC TRACKS")
    print("Repo: " .. MUSIC_REPO_USER .. "/" .. MUSIC_REPO_NAME)
    print("")

    if not ok then
        print("Failed: " .. tostring(result))
    else
        for i, track in ipairs(musicTracks) do
            local sizeKb = track.size and math.floor(track.size / 1024) or 0
            print(tostring(i) .. ". " .. tostring(track.name) .. " [" .. tostring(sizeKb) .. "KB]")
        end
    end

    line()
    print("")
end

local function playMusicTrack(track)
    if not track then
        print("[MUSIC] No track selected.")
        return false
    end

    scanSpeakers()

    if #citySpeakers == 0 then
        print("[MUSIC] No speakers visible.")
        return false
    end

    print("[MUSIC] Opening stream: " .. tostring(track.name))
    print("[MUSIC] Sending music request to wireless speaker nodes...")
    nodeMusic(track)
    sleep(PA_NODE_PRESTART_DELAY)
    print("[MUSIC] Broadcasting to direct wired speakers: " .. tostring(#activeBroadcastSpeakers()) .. "/" .. tostring(#citySpeakers) .. " active speaker(s).")

    local handle = http.get(track.url, {
        ["User-Agent"] = "CC-Tweaked-JARVIS-Music",
    }, true)

    if not handle then
        print("[MUSIC] Stream failed: no HTTP handle.")
        return false
    end

    local code = "?"
    if handle.getResponseCode then
        local okCode, c = pcall(function() return handle.getResponseCode() end)
        if okCode then code = tostring(c) end
    end

    print("[MUSIC] Stream HTTP " .. tostring(code))

    local okPlay, errPlay = pcall(function()
        local dfpwm = require("cc.audio.dfpwm")
        local decoder = dfpwm.make_decoder()
        local chunks = 0
        local bytes = 0

        while true do
            local chunk = handle.read(MUSIC_CHUNK_SIZE or 16384)
            if not chunk then break end

            chunks = chunks + 1
            bytes = bytes + #chunk

            if chunks == 1 then
                print("[MUSIC] First audio chunk: " .. tostring(#chunk) .. " bytes.")
            end

            local audio = decoder(chunk)
            local played, playErr = playAudioBufferOnAll(audio, MUSIC_VOLUME or 1, false, nil)

            if not played then
                error(playErr or "speaker playback failed")
            end
        end

        print("[MUSIC] Finished. Chunks=" .. tostring(chunks) .. " Bytes=" .. tostring(bytes))
    end)

    handle.close()

    if not okPlay then
        print("[MUSIC] Playback error: " .. tostring(errPlay))
        return false
    end

    return true
end

local function playRandomMusic()
    local ok, result = ensureTracks()

