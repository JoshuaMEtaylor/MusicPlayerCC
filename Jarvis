end

local function diffSpeakerBaseline()
    local baseline = readSpeakerBaseline()

    if not baseline then
        print("No speaker baseline saved yet.")
        print("Run: spbase")
        return nil
    end

    scanSpeakers()

    local current = {}

    for _, item in ipairs(citySpeakers) do
        current[#current + 1] = tostring(item.name)
    end

    table.sort(current)

    local baseSet = tableSet(baseline)
    local currSet = tableSet(current)

    local missing = {}
    local new = {}

    for _, name in ipairs(baseline) do
        if not currSet[name] then
            missing[#missing + 1] = name
        end
    end

    for _, name in ipairs(current) do
        if not baseSet[name] then
            new[#new + 1] = name
        end
    end

    print("")
    line()
    print("SPEAKER BASELINE DIFF")
    print("Baseline: " .. tostring(#baseline))
    print("Current:  " .. tostring(#current))
    print("Missing:  " .. tostring(#missing))
    print("New:      " .. tostring(#new))
    print("")

    if #missing > 0 then
        print("Missing speaker name(s):")
        for _, name in ipairs(missing) do
            print("  " .. tostring(name))
        end
        print("")
        print("If you disconnected the broken physical speaker, disable it with:")
        for _, name in ipairs(missing) do
            print("  spoffname " .. tostring(name))
        end
    else
        print("No baseline speakers are missing.")
    end

    if #new > 0 then
        print("")
        print("New speaker name(s):")
        for _, name in ipairs(new) do
            print("  " .. tostring(name))
        end
    end

    line()
    print("")

    return {
        baseline = baseline,
        current = current,
        missing = missing,
        new = new,
    }
end

