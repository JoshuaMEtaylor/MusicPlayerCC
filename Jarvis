            if type(data) == "table" then
                for _, item in ipairs(data) do
                    if type(item) == "table" and item.type == "file" and type(item.name) == "string" then
                        if item.name:lower():match("%.dfpwm$") then
                            found[#found + 1] = {
                                name = item.name,
                                display = niceTrackName(item.name),
                                url = musicUrlRawGithub(item.name),
                                alt_url = musicUrlGithubRaw(item.name),
                                size = tonumber(item.size) or 0,
                                source = "github_api",
                            }
                        end
                    end
                end
            elseif debug then
                print("[MUSIC] Could not parse GitHub API JSON.")
            end
        elseif debug then
            print("[MUSIC] GitHub API request failed.")
        end
    end

    if #found == 0 then
        if debug then print("[MUSIC] Using fallback track list.") end
        addFallbackTracks(found)
    end

    table.sort(found, function(a, b) return tostring(a.display) < tostring(b.display) end)
    musicTracks = found
    return found
end

