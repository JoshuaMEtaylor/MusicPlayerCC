local function lastMorningDay()
    local text = trim(readAll(MORNING_STATE_FILE) or "")
    return tonumber(text)
end

local function saveMorningDay(day)
    writeFile(MORNING_STATE_FILE, tostring(day))
end

local function readMorningHistory()
    return limitText(readAll(MORNING_HISTORY_FILE) or "", MORNING_HISTORY_MAX_CHARS)
end

local function appendMorningHistory(day, text)
    local entry = "\n\n--- DAY " .. tostring(day) .. " ---\n" .. tostring(text or "")
    local existing = readAll(MORNING_HISTORY_FILE) or ""
    local combined = limitText(existing .. entry, MORNING_HISTORY_MAX_CHARS)
    writeFile(MORNING_HISTORY_FILE, combined)
end

local function fallbackMorningBroadcast(clock)
    return table.concat({
        "Good morning, citizens of the Ako Dynasty.",
        "",
        "From the red and black banners of Ako, this city wakes to order. Let every street, workshop, field, and ledger remember its place within the Dynasty's design.",
        "",
        "By discipline we prevent disorder. By labour we preserve strength. By loyalty we ensure that the city moves with one mind beneath the authority of Ako.",
        "",
        "Citizens are now directed to receive the approved daily patriotic music programme. Let its rhythm carry compliance, confidence, and unity through every district.",
        "",
        "Remain productive. Remain orderly. The Ako Dynasty advances."
    }, "\n")
end

local function generateMorningBroadcast(clock, forced)
    local history = readMorningHistory()

    local morningSystem = [=[
You are JARVIS State Radio, the fictional official public-address broadcaster of a Minecraft town.

Generate one fresh morning city broadcast.

Purpose:
- This message is for a town broadcasting system.
- It will be played throughout the city over public speakers using text-to-speech.
- It exists to encourage civic order, compliance, morale, productivity, and continued loyalty.
- It should introduce the daily patriotic/propaganda music programme near the end.

Fictional state identity:
- Nation: the Ako Dynasty.
- Leader: Ako.
- Colours: red and black.
- Theme: East Asian dynastic/state-radio aesthetic.

Style:
- Grand, ceremonial, confident, official news-presenter tone.
- Similar energy to an extremely loyal state broadcaster, but completely fictional and in-world.
- Use imagery of banners, dawn, order, duty, workshops, streets, bells, ledgers, furnaces, citizens, and dynasty where useful.
- Make it sound like a dramatic public broadcast opening echoing through a city.
- It should be unique and not reuse previous wording.
- Keep it between 90 and 130 words. TTS needs it concise.

Restrictions:
- Do not reference real-world country names, real-world political parties, real-world ethnic claims, real leaders, or real regimes.
- Do not mention China, North Korea, communism, fascism, or any real government.
- Do not use markdown.
- Do not use JSON.
- Return only the broadcast text.
]=]

    local userPrompt = table.concat({
        "Create today's morning public broadcast for the city.",
        "",
        "Minecraft date: " .. tostring(clock.date_text),
        "Minecraft time: " .. tostring(clock.time_text),
        "Absolute Minecraft day: " .. tostring(clock.absolute_day),
        "Forced test: " .. tostring(forced == true),
        "Visible city speakers: " .. tostring(speakerCount()),
        "",
        "Avoid repeating these previous broadcasts:",
        history ~= "" and history or "No previous broadcasts recorded.",
    }, "\n")

    local reply, err = callOpenAI({
        {
            role = "user",
            content = userPrompt
        }
    }, morningSystem)

    if not reply then
        return fallbackMorningBroadcast(clock), "GPT morning generation failed: " .. tostring(err)
    end

    reply = trim(reply)

    if reply == "" then
        return fallbackMorningBroadcast(clock), "GPT morning generation returned empty text."
    end

    return reply, nil
end

local function printMorningBroadcast(forced)
    local c = minecraftClock()

    print("")
    line()
    print("JARVIS MORNING TOWN BROADCAST")
    print("Nation: " .. NATION_NAME)
    print("Leader: " .. LEADER_NAME)
    print("Colours: " .. STATE_COLOURS)
    print("Purpose: city-wide compliance and loyalty broadcast")
    print("Visible speakers: " .. tostring(speakerCount()))
    print("TTS: " .. (TTS_ENABLED and "enabled" or "disabled"))
    print("Date: " .. c.date_text .. "  Time: " .. c.time_text)
    print("")

    stopMusic("morning broadcast")
    playOnAllSpeakers("minecraft:block.note_block.chime", 1, 1.0)
    sleep(0.15)
    playOnAllSpeakers("minecraft:block.note_block.chime", 1, 1.25)

    print("Composing fresh public broadcast...")
    local speech, err = generateMorningBroadcast(c, forced)

    print("")
    print(speech)
    print("")

    if err then
        print("NOTICE: " .. err)
        print("")
    end

    local okSpeak, speakErr = speakToCity(speech, true)
    if not okSpeak then
        print("TTS warning: " .. tostring(speakErr))
    end

    print("")
    print("Selecting daily patriotic music through JARVIS...")
    playRandomMusic()

    if not forced then
        appendMorningHistory(c.absolute_day, speech)
    else
        print("")
        print("(Forced test broadcast. Daily trigger state/history was not changed.)")
    end

    line()
    print("")
end

local function shouldRunMorningBroadcast()
    if not MORNING_ENABLED then return false end

    local c = minecraftClock()
    local last = lastMorningDay()

    if last == c.absolute_day then return false end

    if c.hour >= MORNING_START_HOUR and c.hour < MORNING_END_HOUR then
        return true, c
    end

    return false
end

local function morningBroadcastLoop()
    while true do
        local ok, c = shouldRunMorningBroadcast()

        if ok and c then
            printMorningBroadcast(false)
            saveMorningDay(c.absolute_day)
        end

        sleep(MORNING_CHECK_SECONDS)
    end
end

