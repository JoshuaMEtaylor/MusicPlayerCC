local function stopMusic(reason)
    if musicState.playing then
        print("[MUSIC] Stopping music" .. (reason and (": " .. tostring(reason)) or "."))
    end

    musicState.stop = true
    musicState.playing = false
    musicState.token = musicState.token + 1
    stopAllSpeakers()
    os.queueEvent("jarvis_music_wake")
