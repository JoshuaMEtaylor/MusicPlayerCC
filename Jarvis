local function openAllPaModems()
    if not rednet or not rednet.open then
        print("[NODE] Rednet API unavailable.")
        return 0
    end

    local opened = 0

    for _, name in ipairs(peripheral.getNames()) do
        if peripheralHasType(name, "modem") and not rednet.isOpen(name) then
            local ok, err = pcall(function()
                rednet.open(name)
            end)

            if ok then
                opened = opened + 1
            else
                print("[NODE] Could not open modem " .. tostring(name) .. ": " .. tostring(err))
            end
        end
    end

    return opened
end

local function nextPaCommandId(prefix)
    paCommandCounter = paCommandCounter + 1
    return tostring(prefix or "cmd") .. "-" .. tostring(os.getComputerID()) .. "-" .. tostring(paCommandCounter) .. "-" .. tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
end

local function rememberNode(id, msg)
    if not id then return end

    speakerNodes[id] = {
        id = id,
        label = tostring(msg and msg.label or ("node-" .. tostring(id))),
        speaker_count = tonumber(msg and msg.speaker_count) or 0,
        speakers = msg and msg.speakers or {},
        version = tostring(msg and msg.version or "?"),
        last_seen = os.epoch and os.epoch("utc") or math.floor(os.clock() * 1000),
    }
end

local function discoverSpeakerNodes(timeout)
    openAllPaModems()

    if not rednet or not rednet.broadcast then
        print("[NODE] Rednet unavailable; cannot discover speaker nodes.")
        return 0
    end

    timeout = timeout or PA_NODE_DISCOVERY_TIMEOUT

    local commandId = nextPaCommandId("discover")
    rednet.broadcast({
        type = "discover",
        command_id = commandId,
        controller = os.getComputerID(),
    }, PA_NODE_PROTOCOL)

    local found = 0
    local deadline = os.clock() + timeout

    while os.clock() < deadline do
        local remaining = deadline - os.clock()
        if remaining <= 0 then break end

        local sender, reply = rednet.receive(PA_NODE_PROTOCOL, remaining)

        if sender and type(reply) == "table" and reply.type == "ack" and reply.command_id == commandId then
            rememberNode(sender, reply)
            found = found + 1
        end
    end

    print("[NODE] Discovery complete: " .. tostring(found) .. " node response(s).")
    return found
end

